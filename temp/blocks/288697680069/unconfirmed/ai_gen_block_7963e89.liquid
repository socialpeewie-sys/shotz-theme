    </div>
  </div>
</div>

<style>
  .shotz-marquee {
    overflow: hidden;
    padding: 60px 0;
  }

  .shotz-marquee__header {
    text-align: center;
    margin-bottom: 48px;
  }

  .shotz-marquee__eyebrow {
    font-size: 12px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: 12px;
    color: rgb(var(--color-foreground));
    opacity: 0.8;
  }

  .shotz-marquee__icon {
    display: inline-block;
    margin-right: 6px;
  }

  .shotz-marquee__heading {
    font-weight: 800;
    margin: 0;
  }

  .shotz-marquee__wrapper {
    overflow: hidden;
    position: relative;
    width: 100%;
    margin: 0 auto;
  }

  .shotz-marquee__track {
    display: flex;
    gap: 20px;
    width: fit-content;
    animation: marquee-scroll linear infinite;
    will-change: transform;
  }

  .shotz-marquee__track:hover {
    animation-play-state: paused;
  }

  @keyframes marquee-scroll {
    0% {
      transform: translateX(0);
    }
    100% {
      transform: translateX(-50%);
    }
  }

  .shotz-marquee__card {
    position: relative;
    width: 280px;
    height: 360px;
    border-radius: 16px;
    overflow: hidden;
    flex-shrink: 0;
    background-color: rgb(var(--color-background));
    box-shadow: 0 2px 8px rgba(0, 0, 0, 0.08);
    transition: transform 0.3s ease, box-shadow 0.3s ease;
  }

  .shotz-marquee__card:hover {
    transform: translateY(-4px);
    box-shadow: 0 8px 24px rgba(0, 0, 0, 0.12);
  }

  .shotz-marquee__image {
    width: 100%;
    height: 100%;
    position: relative;
  }

  .shotz-marquee__image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .shotz-marquee__placeholder {
    background: linear-gradient(135deg, #faf7f2 0%, #ede4d6 100%);
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .shotz-marquee__placeholder svg {
    width: 80px;
    height: 80px;
    opacity: 0.3;
  }

  .shotz-marquee__label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 12px 16px;
    color: #ffffff;
    font-weight: 600;
    font-size: 14px;
    text-align: center;
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
  }

  @media screen and (max-width: 749px) {
    .shotz-marquee {
      padding: 40px 0;
    }

    .shotz-marquee__header {
      margin-bottom: 32px;
    }

    .shotz-marquee__card {
      width: 240px;
      height: 320px;
    }

    .shotz-marquee__track {
      gap: 16px;
    }
  }
</style>

{% schema %}
{
