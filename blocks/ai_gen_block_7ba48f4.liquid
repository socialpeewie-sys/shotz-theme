{% doc %}
  @prompt
    Seletor de sabores e quantidades para o tema Horizon da Shopify.
    Visual customizado que aciona o seletor nativo do Horizon para garantir
    que preço, imagem e título atualizem corretamente.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-variant-selector-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  /* Esconde o seletor nativo — nosso bloco assume o visual */
  .variant-picker {
    display: none !important;
  }

  .ai-flavor-section-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-flavor-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.flavor_label_font_size }}px;
    font-weight: {{ block.settings.flavor_label_font_weight }};
    color: {{ block.settings.flavor_label_color }};
    margin-bottom: {{ block.settings.flavor_label_spacing }}px;
    display: {% if block.settings.show_flavor_label %}block{% else %}none{% endif %};
  }

  .ai-flavor-title-{{ ai_gen_id }} {
    display: none;
  }

  .ai-flavor-grid-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.flavor_grid_gap }}px;
    flex-wrap: wrap;
  }

  .ai-flavor-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .ai-flavor-card-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.flavor_thumbnail_size }}px;
    height: {{ block.settings.flavor_thumbnail_size }}px;
    border: {{ block.settings.flavor_border_width }}px solid {{ block.settings.flavor_border_color }};
    border-radius: {{ block.settings.flavor_border_radius }}px;
    overflow: hidden;
    cursor: pointer;
    transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.22s ease,
                border-color 0.18s ease;
  }

  .ai-flavor-card-{{ ai_gen_id }}:hover {
    border-color: {{ block.settings.flavor_hover_border_color }};
    transform: translateY(-4px) scale(1.06);
    box-shadow: 0 10px 24px rgba(0, 148, 246, 0.2);
  }

  .ai-flavor-card-{{ ai_gen_id }}.selected {
    border-color: {{ block.settings.flavor_selected_border_color }};
    border-width: {{ block.settings.flavor_selected_border_width }}px;
  }

  .ai-flavor-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-flavor-overlay-{{ ai_gen_id }} {
    font-size: {{ block.settings.overlay_font_size }}px;
    color: {{ block.settings.overlay_text_color }};
    text-align: center;
    width: {{ block.settings.flavor_thumbnail_size }}px;
    word-break: break-word;
    display: {% if block.settings.show_flavor_overlay %}block{% else %}none{% endif %};
  }

  .ai-flavor-checkmark-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.checkmark_position }}px;
    right: {{ block.settings.checkmark_position }}px;
    width: {{ block.settings.checkmark_size }}px;
    height: {{ block.settings.checkmark_size }}px;
    background-color: {{ block.settings.checkmark_background }};
    border-radius: 50%;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .ai-flavor-card-{{ ai_gen_id }}.selected .ai-flavor-checkmark-{{ ai_gen_id }} {
    display: flex;
  }

  .ai-flavor-checkmark-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    fill: {{ block.settings.checkmark_icon_color }};
  }

  .ai-quantity-section-{{ ai_gen_id }} {
    margin-top: {{ block.settings.section_spacing }}px;
  }

  .ai-quantity-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.quantity_label_font_size }}px;
    font-weight: {{ block.settings.quantity_label_font_weight }};
    color: {{ block.settings.quantity_label_color }};
    margin-bottom: {{ block.settings.quantity_label_spacing }}px;
    display: {% if block.settings.show_quantity_label %}block{% else %}none{% endif %};
  }

  .ai-quantity-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: {{ block.settings.quantity_grid_gap }}px;
  }

  @keyframes ai-select-bounce-{{ ai_gen_id }} {
    0%   { transform: scale(1); }
    35%  { transform: scale(0.93); }
    100% { transform: scale(1); }
  }

  .ai-quantity-card-{{ ai_gen_id }} {
    position: relative;
    padding: {{ block.settings.quantity_card_padding }}px;
    border: {{ block.settings.quantity_card_border_width }}px solid {{ block.settings.quantity_card_border_color }};
    border-radius: {{ block.settings.quantity_card_border_radius }}px;
    background-color: {{ block.settings.quantity_card_background }};
    cursor: pointer;
    transition: background-color 0.2s ease,
                border-color 0.2s ease,
                box-shadow 0.2s ease;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
    margin-top: 12px;
  }

  .ai-quantity-card-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.quantity_card_hover_background }};
    border-color: {{ block.settings.quantity_card_hover_border_color }};
    box-shadow: 0 4px 12px rgba(0, 148, 246, 0.1);
  }

  .ai-quantity-card-{{ ai_gen_id }}.selected {
    background-color: {{ block.settings.quantity_card_selected_background }};
    border-color: {{ block.settings.quantity_card_selected_border_color }};
    border-width: {{ block.settings.quantity_card_selected_border_width }}px;
    animation: ai-select-bounce-{{ ai_gen_id }} 0.32s cubic-bezier(0.34, 1.56, 0.64, 1);
  }

  .ai-quantity-radio-{{ ai_gen_id }} {
    width: {{ block.settings.radio_size }}px;
    height: {{ block.settings.radio_size }}px;
    border: {{ block.settings.radio_border_width }}px solid {{ block.settings.radio_border_color }};
    border-radius: 50%;
    position: relative;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .ai-quantity-card-{{ ai_gen_id }}.selected .ai-quantity-radio-{{ ai_gen_id }} {
    border-color: {{ block.settings.radio_selected_border_color }};
    background-color: {{ block.settings.radio_selected_background }};
  }

  .ai-quantity-card-{{ ai_gen_id }}.selected .ai-quantity-radio-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 50%;
    height: 50%;
    background-color: {{ block.settings.radio_selected_dot_color }};
    border-radius: 50%;
  }

  .ai-quantity-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.quantity_title_font_size }}px;
    font-weight: {{ block.settings.quantity_title_font_weight }};
    color: {{ block.settings.quantity_title_color }};
    text-align: center;
  }

  .ai-quantity-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.quantity_price_font_size }}px;
    font-weight: {{ block.settings.quantity_price_font_weight }};
    color: {{ block.settings.quantity_price_color }};
    text-align: center;
  }

  .ai-quantity-badge-{{ ai_gen_id }} {
    position: absolute;
    top: -11px;
    left: 50%;
    transform: translateX(-50%);
    padding: 3px 10px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 700;
    white-space: nowrap;
    z-index: 1;
  }

  .ai-quantity-discount-badge-{{ ai_gen_id }} {
    background-color: {{ block.settings.discount_badge_background }};
    color: {{ block.settings.discount_badge_text }};
  }

  .ai-quantity-shipping-badge-{{ ai_gen_id }} {
    background-color: {{ block.settings.shipping_badge_background }};
    color: {{ block.settings.shipping_badge_text }};
    position: static;
    transform: none;
    margin-top: 2px;
    padding: 2px 8px;
    font-size: {{ block.settings.shipping_badge_font_size }}px;
    border-radius: 4px;
  }

  @media screen and (max-width: 749px) {
    .ai-flavor-card-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_flavor_thumbnail_size }}px;
      height: {{ block.settings.mobile_flavor_thumbnail_size }}px;
    }

    .ai-flavor-overlay-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_flavor_thumbnail_size }}px;
    }

    .ai-quantity-grid-{{ ai_gen_id }} {
      grid-template-columns: repeat(3, 1fr);
      gap: {{ block.settings.mobile_quantity_grid_gap }}px;
    }

    .ai-quantity-card-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_quantity_card_padding }}px;
    }

    .ai-quantity-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_quantity_title_font_size }}px;
    }

    .ai-quantity-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_quantity_price_font_size }}px;
    }
  }
{% endstyle %}

<variant-selector-{{ ai_gen_id }}
  class="ai-variant-selector-{{ ai_gen_id }}"
  data-product-id="{{ product.id }}"
  {{ block.shopify_attributes }}
>
  {%- comment -%} SELETOR DE SABOR {%- endcomment -%}
  <div class="ai-flavor-section-{{ ai_gen_id }}">
    {% if block.settings.flavor_label_text != blank %}
      <div class="ai-flavor-label-{{ ai_gen_id }}">{{ block.settings.flavor_label_text }}</div>
    {% endif %}

    <div class="ai-flavor-title-{{ ai_gen_id }}" data-flavor-title>
      {{ product.selected_or_first_available_variant.option1 | default: 'Selecione um sabor' }}
    </div>

    <div class="ai-flavor-grid-{{ ai_gen_id }}">
      {% assign flavors_added = '' %}
      {% for variant in product.variants %}
        {% assign variant_options = variant.title | split: ' / ' %}
        {% assign flavor = variant_options[0] %}
        {% unless flavors_added contains flavor %}
          {% assign flavors_added = flavors_added | append: flavor | append: ',' %}
          <div class="ai-flavor-item-{{ ai_gen_id }}">
            <div
              class="ai-flavor-card-{{ ai_gen_id }} {% if variant.option1 == product.selected_or_first_available_variant.option1 %}selected{% endif %}"
              data-flavor="{{ flavor }}"
              data-option1="{{ flavor }}"
            >
              {% if variant.featured_image %}
                <img src="{{ variant.featured_image | image_url: width: 200 }}" alt="{{ flavor }}" class="ai-flavor-image-{{ ai_gen_id }}" loading="lazy">
              {% elsif product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ flavor }}" class="ai-flavor-image-{{ ai_gen_id }}" loading="lazy">
              {% endif %}
              <div class="ai-flavor-checkmark-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
              </div>
            </div>
            <div class="ai-flavor-overlay-{{ ai_gen_id }}">{{ flavor }}</div>
          </div>
        {% endunless %}
      {% endfor %}
    </div>
  </div>

  {%- comment -%} SELETOR DE QUANTIDADE {%- endcomment -%}
  <div class="ai-quantity-section-{{ ai_gen_id }}">
    {% if block.settings.quantity_label_text != blank %}
      <div class="ai-quantity-label-{{ ai_gen_id }}">{{ block.settings.quantity_label_text }}</div>
    {% endif %}

    <div class="ai-quantity-grid-{{ ai_gen_id }}" data-quantity-grid>
      {% assign current_variant = product.selected_or_first_available_variant %}
      {% assign current_flavor = current_variant.option1 %}

      {% for variant in product.variants %}
        {% assign variant_flavor = variant.option1 %}
        {% assign variant_quantity = variant.option2 | default: variant.option1 %}

        {% if variant_flavor == current_flavor %}
          {% assign quantity_number = variant_quantity | remove: ' unidades' | remove: 'unidades' | strip | times: 1 %}
          {% assign unit_price = 0 %}
          {% if quantity_number > 0 %}
            {% assign unit_price = variant.price | divided_by: quantity_number %}
          {% endif %}

          {% assign discount_percent = 0 %}
          {% if variant.compare_at_price > variant.price %}
            {% assign price_diff = variant.compare_at_price | minus: variant.price %}
            {% assign discount_percent = price_diff | times: 100.0 | divided_by: variant.compare_at_price | round %}
          {% endif %}

          <div
            class="ai-quantity-card-{{ ai_gen_id }} {% if variant.id == current_variant.id %}selected{% endif %}"
            data-variant-id="{{ variant.id }}"
            data-option1="{{ variant.option1 }}"
            data-option2="{{ variant.option2 }}"
          >
            {% if discount_percent > 0 %}
              <div class="ai-quantity-badge-{{ ai_gen_id }} ai-quantity-discount-badge-{{ ai_gen_id }}">
                {{ discount_percent }}% OFF
              </div>
            {% endif %}

            <div class="ai-quantity-radio-{{ ai_gen_id }}"></div>

            <div class="ai-quantity-title-{{ ai_gen_id }}">{{ variant_quantity }}</div>

            {% if unit_price > 0 %}
              <div class="ai-quantity-price-{{ ai_gen_id }}">
                {{ unit_price | money }}/cada
              </div>
            {% endif %}

            {% if variant.metafields.custom.free_shipping == true %}
              <span class="ai-quantity-badge-{{ ai_gen_id }} ai-quantity-shipping-badge-{{ ai_gen_id }}">
                FRETE GRÁTIS
              </span>
            {% endif %}
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</variant-selector-{{ ai_gen_id }}>

<script>
(function() {
  const id = '{{ ai_gen_id }}';
  const productVariants = {{ product.variants | json }};

  function formatMoney(cents) {
    return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(cents / 100);
  }

  function triggerNativeRadio(optionValue) {
    const radios = document.querySelectorAll(
      `.variant-picker input[type="radio"][aria-label="${optionValue}"],
       .variant-picker input[type="radio"][value="${optionValue}"]`
    );
    radios.forEach(radio => {
      if (!radio.checked) {
        radio.checked = true;
        radio.dispatchEvent(new Event('change', { bubbles: true }));
        radio.dispatchEvent(new Event('input', { bubbles: true }));
      }
    });
  }

  function applyQuantitySelection(variantId) {
    document.querySelectorAll(`.ai-quantity-card-${id}`).forEach(c => {
      const isSelected = parseInt(c.dataset.variantId) === variantId;
      c.classList.toggle('selected', isSelected);
      c.style.borderColor = isSelected
        ? '{{ block.settings.quantity_card_selected_border_color }}'
        : '{{ block.settings.quantity_card_border_color }}';
      c.style.background = isSelected
        ? '{{ block.settings.quantity_card_selected_background }}'
        : '{{ block.settings.quantity_card_background }}';
      const radioEl = c.querySelector('.q-radio');
      if (radioEl) {
        radioEl.style.borderColor = isSelected
          ? '{{ block.settings.radio_selected_border_color }}'
          : '{{ block.settings.radio_border_color }}';
        radioEl.style.background = isSelected ? '{{ block.settings.radio_selected_background }}' : '#fff';
        radioEl.style.boxShadow = isSelected ? 'inset 0 0 0 3px #fff' : 'none';
      }
    });
  }

  function updateQuantityCards(flavor) {
    const grid = document.querySelector('[data-quantity-grid]');
    if (!grid) return;

    grid.innerHTML = '';

    const flavorVariants = productVariants.filter(v => v.option1 === flavor);
    const currentInput = document.querySelector('input[name="id"]');
    const currentId = currentInput ? parseInt(currentInput.value) : null;
    const selectedVariant = flavorVariants.find(v => v.id === currentId) || flavorVariants[0];

    flavorVariants.forEach(variant => {
      const qty = variant.option2 || variant.option1;
      const qtyNum = parseInt(qty.replace(/[^0-9]/g, '')) || 0;
      const unitPrice = qtyNum > 0 ? variant.price / qtyNum : 0;

      let discountPct = 0;
      if (variant.compare_at_price > variant.price) {
        discountPct = Math.round((variant.compare_at_price - variant.price) / variant.compare_at_price * 100);
      }

      const card = document.createElement('div');
      card.className = `ai-quantity-card-${id}`;
      card.dataset.variantId = variant.id;
      card.dataset.option1 = variant.option1;
      card.dataset.option2 = variant.option2 || '';
      card.style.cssText = 'position:relative;padding:16px 10px;border:1.5px solid {{ block.settings.quantity_card_border_color }};border-radius:12px;background:{{ block.settings.quantity_card_background }};cursor:pointer;display:flex;flex-direction:column;align-items:center;gap:6px;margin-top:12px;transition:all 0.2s;';

      let html = '';
      if (discountPct > 0) {
        html += `<div style="position:absolute;top:-11px;left:50%;transform:translateX(-50%);background:{{ block.settings.discount_badge_background }};color:{{ block.settings.discount_badge_text }};font-size:11px;font-weight:700;padding:3px 10px;border-radius:20px;white-space:nowrap;z-index:1;">${discountPct}% OFF</div>`;
      }
      html += `<div class="q-radio" style="width:18px;height:18px;border-radius:50%;border:2px solid {{ block.settings.radio_border_color }};background:#fff;flex-shrink:0;transition:all 0.2s;"></div>`;
      html += `<div style="font-size:{{ block.settings.quantity_title_font_size }}px;font-weight:{{ block.settings.quantity_title_font_weight }};color:{{ block.settings.quantity_title_color }};text-align:center;">${qty}</div>`;
      if (unitPrice > 0) {
        html += `<div style="font-size:{{ block.settings.quantity_price_font_size }}px;font-weight:{{ block.settings.quantity_price_font_weight }};color:{{ block.settings.quantity_price_color }};text-align:center;">${formatMoney(unitPrice)}/cada</div>`;
      }

      card.innerHTML = html;
      grid.appendChild(card);
    });

    if (selectedVariant) applyQuantitySelection(selectedVariant.id);
  }

  function selectFlavor(card) {
    document.querySelectorAll(`.ai-flavor-card-${id}`).forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');

    const flavor = card.dataset.option1;
    const titleEl = document.querySelector('[data-flavor-title]');
    if (titleEl) titleEl.textContent = flavor;

    triggerNativeRadio(flavor);

    // Aguarda Horizon atualizar input[name="id"] antes de reconstruir os cards
    setTimeout(() => {
      updateQuantityCards(flavor);
      const firstCard = document.querySelector(`.ai-quantity-card-${id}`);
      if (firstCard) triggerNativeRadio(firstCard.dataset.option2);
    }, 0);
  }

  function selectQuantity(card) {
    const variantId = parseInt(card.dataset.variantId);
    applyQuantitySelection(variantId);
    triggerNativeRadio(card.dataset.option2);
    // Re-sincroniza visual após qualquer atualização assíncrona do Horizon
    requestAnimationFrame(() => applyQuantitySelection(variantId));
  }

  function setup() {
    document.querySelectorAll(`.ai-flavor-card-${id}`).forEach(card => {
      card.addEventListener('click', () => selectFlavor(card));
    });

    // Event delegation no grid — persiste após reconstrução dos cards
    const grid = document.querySelector('[data-quantity-grid]');
    if (grid) {
      grid.addEventListener('click', e => {
        const card = e.target.closest(`.ai-quantity-card-${id}`);
        if (card) selectQuantity(card);
      });
    }
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', setup);
  } else {
    setup();
  }
})();
</script>

<script>
(function () {
  /* ── Config do Admin (editável no Shopify) ──────────────── */
  var EXTRA_DISCOUNT = {{ block.settings.sub_extra_discount | default: 15 }};
  var FREE_SHIPPING  = {{ block.settings.sub_free_shipping }};
  var BENEFITS = [
    {{ block.settings.sub_benefit_1 | json }},
    {{ block.settings.sub_benefit_2 | json }},
    {{ block.settings.sub_benefit_3 | json }},
    {{ block.settings.sub_benefit_4 | json }}
  ].filter(function (b) { return b && b.trim(); });
  var LINK_TEXT = {{ block.settings.sub_benefits_link_text | json }};
  var LINK_URL  = {{ block.settings.sub_benefits_link_url | default: '#' | json }};

  var productVariants = {{ product.variants | json }};

  /* ── Utilitários ─────────────────────────────────────────── */
  function money(cents) {
    return new Intl.NumberFormat('pt-BR', {
      style: 'currency', currency: 'BRL'
    }).format(cents / 100);
  }

  function getQty(variant) {
    var s = (variant.option2 || variant.option1 || '1').replace(/[^0-9]/g, '');
    return parseInt(s) || 1;
  }

  /* Nodes que injetamos — o MutationObserver ignora essas mutações */
  var ourNodes = new WeakSet();

  function isOurNode(node) {
    var el = node;
    while (el && el !== document.body) {
      if (ourNodes.has(el)) return true;
      el = el.parentNode;
    }
    return false;
  }

  /* ── Injeta a UI neon no card de assinatura ─────────────── */
  var injected = false;

  function buildBadgeText() {
    var parts = [];
    if (EXTRA_DISCOUNT > 0) parts.push('+' + EXTRA_DISCOUNT + '% extra');
    if (FREE_SHIPPING)       parts.push('Frete Grátis');
    return parts.join(' + ');
  }

  function injectSubUI(widget) {
    if (injected) return;
    var subGroup = widget.querySelector('.subscription_group:has(.group_name)');
    if (!subGroup) return;
    injected = true;

    /* 1. Header: preço espelhado + chevron */
    var header = subGroup.querySelector(':scope > .title_and_price_wrapper');
    if (header) {
      var hPriceWrap = document.createElement('div');
      ourNodes.add(hPriceWrap);
      hPriceWrap.innerHTML =
        '<div class="sss-header-price" data-sss-hp>' +
          '<span data-sss-hp-price></span><em>/mês</em>' +
          '<span class="sss-header-unit" data-sss-hp-unit></span>' +
        '</div>';
      header.appendChild(hPriceWrap);

      var chevron = document.createElement('div');
      chevron.className = 'sss-chevron';
      chevron.innerHTML =
        '<svg width="12" height="8" viewBox="0 0 12 8" fill="none" aria-hidden="true">' +
          '<path d="M1 1.5L6 6.5L11 1.5" stroke="#0D0D0D" stroke-width="1.8"' +
                ' stroke-linecap="round" stroke-linejoin="round"/>' +
        '</svg>';
      ourNodes.add(chevron);
      header.appendChild(chevron);

      /* Accordion toggle no header (sem mudar seleção do app) */
      header.style.cursor = 'pointer';
      header.addEventListener('click', function (e) {
        if (e.target.closest('.group_list_item')) return;
        subGroup.classList.toggle('sss-expanded');
      });
    }

    /* 2. Corpo expansível: savings + badge + benefícios + link */
    var body = document.createElement('div');
    body.className = 'sss-body';
    ourNodes.add(body);

    var inner = document.createElement('div');
    inner.className = 'sss-body-inner';
    body.appendChild(inner);

    /* Divisor */
    var div = document.createElement('div');
    div.className = 'sss-divider';
    inner.appendChild(div);

    /* Economize */
    var savRow = document.createElement('div');
    savRow.className = 'sss-savings';
    savRow.setAttribute('data-sss-savings', '');
    savRow.style.display = 'none';
    savRow.innerHTML =
      '<span aria-hidden="true">💚</span>' +
      '<span>Economize <strong data-sss-savings-val></strong> por ano</span>';
    ourNodes.add(savRow);
    inner.appendChild(savRow);

    /* Badge neon */
    var badgeText = buildBadgeText();
    if (badgeText) {
      var badgeWrap = document.createElement('div');
      var badge = document.createElement('span');
      badge.className = 'sss-neon-badge';
      badge.textContent = badgeText;
      ourNodes.add(badge);
      ourNodes.add(badgeWrap);
      badgeWrap.appendChild(badge);
      inner.appendChild(badgeWrap);
    }

    /* Benefícios */
    if (BENEFITS.length > 0) {
      var ul = document.createElement('ul');
      ul.className = 'sss-benefits';
      ourNodes.add(ul);
      BENEFITS.forEach(function (text) {
        var li = document.createElement('li');
        li.className = 'sss-benefit';
        li.innerHTML =
          '<span class="sss-check" aria-hidden="true">' +
            '<svg width="8" height="6" viewBox="0 0 8 6" fill="none">' +
              '<path d="M1 3L3 5.2L7 1" stroke="#0D0D0D" stroke-width="1.6"' +
                   ' stroke-linecap="round" stroke-linejoin="round"/>' +
            '</svg>' +
          '</span>' +
          '<span>' + text + '</span>';
        ul.appendChild(li);
      });
      inner.appendChild(ul);
    }

    /* Link */
    if (LINK_TEXT && LINK_TEXT.trim()) {
      var link = document.createElement('a');
      link.className = 'sss-link';
      link.href = LINK_URL || '#';
      link.textContent = LINK_TEXT + ' →';
      ourNodes.add(link);
      inner.appendChild(link);
    }

    subGroup.appendChild(body);

    /* Começa expandido */
    subGroup.classList.add('sss-expanded');
  }

  /* ── Preço por unidade em cada in_widget_price ──────────── */
  function setUnit(priceEl, text) {
    if (!priceEl) return;
    var small = priceEl.querySelector('[data-sub-unit-price]');
    if (!small) {
      small = document.createElement('small');
      small.dataset.subUnitPrice = '1';
      ourNodes.add(small);
      priceEl.appendChild(small);
    }
    small.textContent = text;
  }

  /* ── Badge de desconto por plano ────────────────────────── */
  function setPlanDiscount(itemEl, pct) {
    if (!itemEl) return;
    var tw = itemEl.querySelector('.title_and_price_wrapper');
    if (!tw) return;
    var badge = itemEl.querySelector('[data-sub-plan-discount]');
    if (!badge) {
      badge = document.createElement('span');
      badge.dataset.subPlanDiscount = '1';
      ourNodes.add(badge);
      var priceEl = tw.querySelector('.in_widget_price');
      if (priceEl) tw.insertBefore(badge, priceEl);
      else tw.appendChild(badge);
    }
    if (pct > 0) {
      badge.textContent = '-' + pct + '% OFF';
      badge.style.display = 'inline-block';
    } else {
      badge.style.display = 'none';
    }
  }

  /* ── Atualiza todos os preços ───────────────────────────── */
  function updatePrices(variant) {
    if (!variant) return;

    var widget = document.querySelector('[id*="subscriptions_app_block"]');
    if (!widget) return;

    injectSubUI(widget);

    var qty    = getQty(variant);
    var allocs = variant.selling_plan_allocations || [];
    var fmt    = function (c) { return money(c) + '/unidade'; };

    /* Compra única — preço por unidade */
    var oneEl = widget.querySelector(
      '.subscription_group:has(.one_time_purchase_option_app_block) .in_widget_price'
    );
    setUnit(oneEl, fmt(variant.price / qty));

    /* Assinatura — cada plano mapeia para sua allocation */
    var items = widget.querySelectorAll(
      '.subscription_group:has(.group_name) .group_list_item'
    );
    items.forEach(function (item, i) {
      var alloc = null;
      var radio = item.querySelector('input[type="radio"]');
      if (radio) {
        var planId = parseInt(radio.value);
        alloc = allocs.find(function (a) { return a.selling_plan_id === planId; });
      }
      if (!alloc) alloc = allocs[i] || allocs[0];
      if (!alloc) return;

      setUnit(item.querySelector('.in_widget_price'), fmt(alloc.price / qty));

      var pct = variant.price > 0
        ? Math.round((variant.price - alloc.price) / variant.price * 100)
        : 0;
      setPlanDiscount(item, pct);
    });

    /* Preço espelhado no header */
    var firstAlloc = allocs[0] || null;
    var hpPrice = widget.querySelector('[data-sss-hp-price]');
    var hpUnit  = widget.querySelector('[data-sss-hp-unit]');
    if (firstAlloc) {
      if (hpPrice) hpPrice.textContent = money(firstAlloc.price);
      if (hpUnit)  hpUnit.textContent  = fmt(firstAlloc.price / qty);
    }

    /* Economize X por ano */
    var savRow = widget.querySelector('[data-sss-savings]');
    if (savRow && firstAlloc) {
      var annual = (variant.price - firstAlloc.price) * 12;
      if (annual > 0) {
        var valEl = savRow.querySelector('[data-sss-savings-val]');
        if (valEl) valEl.textContent = money(annual);
        savRow.style.display = '';
      } else {
        savRow.style.display = 'none';
      }
    }
  }

  /* ── Variante atual ─────────────────────────────────────── */
  function getCurrentVariantId() {
    var input = document.querySelector('input[name="id"]');
    return input ? parseInt(input.value) : null;
  }

  function handleVariantId(id) {
    var v = productVariants.find(function (v) { return v.id === id; });
    updatePrices(v);
  }

  /* ── Eventos de mudança de variante ─────────────────────── */
  document.addEventListener('variant:changed', function (e) {
    var v = e.detail && e.detail.variant;
    if (v) { updatePrices(v); return; }
    var id = getCurrentVariantId();
    if (id) handleVariantId(id);
  });

  document.addEventListener('change', function (e) {
    if (e.target && e.target.name === 'id') {
      handleVariantId(parseInt(e.target.value));
    }
  });

  /* Clique no grid de quantidade */
  function setupGridListener() {
    var grid = document.querySelector('[data-quantity-grid]');
    if (!grid) return;
    grid.addEventListener('click', function (e) {
      var card = e.target.closest('[data-variant-id]');
      if (!card) return;
      var vid = parseInt(card.dataset.variantId);
      if (!vid) return;
      [0, 150, 400, 800, 1500].forEach(function (d) {
        setTimeout(function () { handleVariantId(vid); }, d);
      });
    });
  }

  /* MutationObserver — re-injeta se o app remover nossos elementos */
  function setupWidgetObserver() {
    var widget = document.querySelector('[id*="subscriptions_app_block"]');
    if (!widget) return;
    var debounce = null;

    var obs = new MutationObserver(function (mutations) {
      var allOurs = mutations.every(function (m) {
        return isOurNode(m.target) ||
          (m.type === 'childList' && m.removedNodes.length === 0 &&
            Array.from(m.addedNodes).every(function (n) { return isOurNode(n); }));
      });
      if (allOurs) return;

      clearTimeout(debounce);
      debounce = setTimeout(function () {
        var id = getCurrentVariantId();
        if (!id) return;
        handleVariantId(id);
        setTimeout(function () { handleVariantId(id); }, 300);
      }, 50);
    });

    obs.observe(widget, { childList: true, subtree: true, characterData: true });
  }

  /* ── Init ────────────────────────────────────────────────── */
  function init() {
    var id = getCurrentVariantId();
    if (id) handleVariantId(id);
    setupGridListener();
    setupWidgetObserver();
  }

  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', init);
  } else {
    setTimeout(init, 600);
  }
})();
</script>

