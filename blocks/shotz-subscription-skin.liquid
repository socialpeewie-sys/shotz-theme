{% comment %}
  shotz-subscription-skin.liquid
  Caminho: blocks/shotz-subscription-skin.liquid

  Estiliza o app nativo de assinaturas da Shopify (Shopify Subscriptions)
  por cima do DOM que ele já renderiza, sem substituí-lo — os radios reais
  continuam funcionando, só a aparência é trocada (via assets/base.css +
  assets/shotz-custom.js, que injeta a marcação .shotz-* dentro do bloco
  do app).

  Este bloco só existe para expor essa aparência como configurações
  editáveis pelo Editor de Temas. Adicione-o UMA ÚNICA VEZ na página
  (em qualquer lugar dentro da seção de informações do produto) — como
  os seletores de CSS são globais (batem com as classes que o JS injeta
  no bloco do app, não com este bloco em si), duas instâncias juntas
  vão gerar regras conflitantes.
{% endcomment %}

{% style %}
  .subscription_group {
    border-radius: {{ block.settings.card_border_radius }}px !important;
  }
  .subscription_group[data-shotz="sub"],
  .subscription_group[data-shotz="onetime"] {
    border: {{ block.settings.card_border_width }}px solid {{ block.settings.card_border_color }} !important;
  }
  .subscription_group[data-shotz="onetime"]:not([data-shotz-sel="true"]):hover {
    border-color: {{ block.settings.card_border_color | color_darken: 10 }} !important;
  }
  .subscription_group[data-shotz="sub"][data-shotz-sel="true"],
  .subscription_group[data-shotz="onetime"][data-shotz-sel="true"] {
    border-color: {{ block.settings.card_selected_border_color }} !important;
    box-shadow: 0 0 0 3px {{ block.settings.card_selected_border_color | color_modify: 'alpha', 0.12 }},
                0 4px 16px rgba(0, 0, 0, 0.07) !important;
  }

  .shotz-dot {
    width: {{ block.settings.radio_size }}px !important;
    height: {{ block.settings.radio_size }}px !important;
    border: {{ block.settings.radio_border_width }}px solid {{ block.settings.radio_border_color }} !important;
  }
  .subscription_group[data-shotz][data-shotz-sel="true"] .shotz-dot {
    background: {{ block.settings.radio_selected_color }} !important;
    border-color: {{ block.settings.radio_selected_color }} !important;
  }
  .shotz-dot-check {
    fill: {{ block.settings.radio_check_color }} !important;
  }

  .shotz-label {
    font-size: {{ block.settings.label_font_size }}px !important;
    font-weight: {{ block.settings.label_font_weight }} !important;
    color: {{ block.settings.label_color }} !important;
  }

  .shotz-badge {
    font-size: {{ block.settings.badge_font_size }}px !important;
    font-weight: {{ block.settings.badge_font_weight }} !important;
    background: {{ block.settings.badge_background }} !important;
    color: {{ block.settings.badge_text_color }} !important;
    border-radius: {{ block.settings.badge_border_radius }}px !important;
  }

  .shotz-price {
    font-size: {{ block.settings.price_font_size }}px !important;
    font-weight: {{ block.settings.price_font_weight }} !important;
    color: {{ block.settings.price_color }} !important;
  }
  .shotz-compare {
    font-size: {{ block.settings.compare_font_size }}px !important;
    color: {{ block.settings.compare_color }} !important;
  }
  .shotz-unit {
    font-size: {{ block.settings.unit_font_size }}px !important;
    font-weight: {{ block.settings.unit_font_weight }} !important;
    color: {{ block.settings.unit_color }} !important;
  }

  .shotz-chevron svg path {
    stroke: {{ block.settings.chevron_color }} !important;
  }

  .shotz-divider {
    background: {{ block.settings.divider_color }} !important;
  }
  .subscription_group[data-shotz="sub"] .shopify_subscriptions_app_policy {
    font-size: {{ block.settings.policy_font_size }}px !important;
    color: {{ block.settings.policy_color }} !important;
  }

  .subscription_group[data-shotz="sub"] .group_list_item.custom_radio_button {
    background: {{ block.settings.freq_pill_background }} !important;
    border: {{ block.settings.freq_pill_border_width }}px solid {{ block.settings.freq_pill_border_color }} !important;
    border-radius: {{ block.settings.freq_pill_border_radius }}px !important;
  }
  .subscription_group[data-shotz="sub"] .group_list_item.custom_radio_button span {
    font-size: {{ block.settings.freq_pill_font_size }}px !important;
    color: {{ block.settings.freq_pill_text_color }} !important;
  }
  .subscription_group[data-shotz="sub"] .group_list_item.custom_radio_button:has(input:checked) {
    background: {{ block.settings.freq_pill_selected_background }} !important;
    border-color: {{ block.settings.freq_pill_selected_border_color }} !important;
  }
  .subscription_group[data-shotz="sub"] .group_list_item.custom_radio_button:has(input:checked) span {
    color: {{ block.settings.freq_pill_selected_text_color }} !important;
  }

  .shotz-feature {
    font-size: {{ block.settings.feature_font_size }}px !important;
    color: {{ block.settings.feature_color }} !important;
  }
  .shotz-check svg path {
    stroke: {{ block.settings.feature_check_icon_color }} !important;
  }

  .shotz-plan-title {
    font-size: {{ block.settings.plan_title_font_size }}px !important;
    font-weight: {{ block.settings.plan_title_font_weight }} !important;
    color: {{ block.settings.plan_title_color }} !important;
  }

  @media screen and (max-width: 749px) {
    .shotz-label  { font-size: {{ block.settings.label_font_size_mobile }}px !important; }
    .shotz-price  { font-size: {{ block.settings.price_font_size_mobile }}px !important; }
    .shotz-unit   { font-size: {{ block.settings.unit_font_size_mobile }}px !important; }
    .shotz-badge  { font-size: {{ block.settings.badge_font_size_mobile }}px !important; }
  }
{% endstyle %}

<script>
  window.ShotzSubSkinConfig = {
    planTitle: {{ block.settings.plan_title_text | json }},
    subLabel: {{ block.settings.sub_label_text | json }},
    oneLabel: {{ block.settings.one_label_text | json }},
    freqLabel: {{ block.settings.freq_label_text | json }},
    features: [
      {% for feature_block in block.blocks %}
        {% if feature_block.type == '_shotz-subscription-feature' and feature_block.settings.text != blank %}
          {{ feature_block.settings.text | json }}{% unless forloop.last %},{% endunless %}
        {% endif %}
      {% endfor %}
    ]
  };
</script>
<div style="display:none" {{ block.shopify_attributes }}></div>

