{% doc %}
  Hero section for the Shotz pre-launch landing page.
{% enddoc %}

<section class="spl-hero">
  <div class="spl-hero__bg">
    {% if section.settings.hero_video %}
      {{
        section.settings.hero_video
        | video_tag:
          image_size: '1500x',
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          class: 'spl-hero__media'
      }}
    {% elsif section.settings.hero_image %}
      {{
        section.settings.hero_image
        | image_url: width: 2000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '(min-width: 900px) 900px, 100vw',
          widths: '750, 1100, 1500, 2000',
          class: 'spl-hero__media'
      }}
    {% else %}
      <div class="spl-hero__placeholder" aria-hidden="true">
        <span>banner: vídeo ou imagem de produto</span>
      </div>
    {% endif %}
    <div class="spl-hero__overlay"></div>
  </div>

  <div class="spl-hero__content">
    <div class="spl-hero__wordmark">SHOTZ</div>

    <h1>Sua rotina já é complexa. Consumir proteína não precisa ser.</h1>
    <p class="spl-hero__subheadline">
      Foi pensando nisso que criamos a Shotz, um shot proteico desenvolvido para tornar o consumo de proteína mais
      simples.
    </p>

    <span class="spl-pill">Cadastre-se e garanta 10% OFF na primeira compra</span>

    <div>
      <button
        type="button"
        class="spl-btn"
        data-spl-open-modal
      >
        Quero acesso antecipado <span class="spl-btn__arrow" aria-hidden="true">↗</span>
      </button>
    </div>

    <p class="spl-hero__footnote">Vagas limitadas.</p>
  </div>
</section>

{% schema %}
{
  "name": "Prelaunch — Hero",
  "settings": [
    {
      "type": "video",
      "id": "hero_video",
      "label": "Vídeo de fundo",
      "info": "Se definido, tem prioridade sobre a imagem de fundo abaixo."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Imagem de fundo",
      "info": "Usada quando nenhum vídeo é definido."
    }
  ]
}
{% endschema %}
