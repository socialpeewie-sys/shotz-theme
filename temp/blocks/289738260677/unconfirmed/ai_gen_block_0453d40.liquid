{% doc %}
  @prompt
    PROMPT PARA CLAUDE CODE - BLOCO SHOPIFY PERSONALIZADO "HERO COM BENEFÍCIOS"
    
    Crie um bloco Liquid customizado para tema Shopify Horizon com as seguintes especificações:
    
    ESTRUTURA VISUAL:
    - Layout: 2 colunas (50/50) responsive
    - Coluna esquerda: imagem do produto (full-height, fundo cor customizável)
    - Coluna direita: conteúdo texto
    
    COLUNA ESQUERDA:
    - Campo: imagem (Shopify image picker)
    - Cor de fundo customizável
    - Border-radius no canto superior direito (arredondado, estilo card)
    - Aspectos: cobrir com padding interno
    
    COLUNA DIREITA:
    - Headline (campo texto): tamanho grande, bold
    - Subtítulo (campo textarea): tamanho médio, cor cinza
    - Lista de benefícios dinâmica:
      ├─ Cada item: checkmark (✓) + texto
      ├─ Máximo 4 itens, cada um em um campo de entrada
      ├─ Checkmark: cor customizável (usar cores existentes do tema)
      └─ Espaçamento: vertical ~12px entre itens
    - CTA Button:
      ├─ Texto customizável
      ├─ Link customizável
      └─ Classe de botão padrão do tema
    
    RESPONSIVIDADE:
    - Desktop: 2 colunas flex
    - Mobile: 1 coluna, imagem no topo, conteúdo abaixo
    
    CAMPOS CUSTOMIZÁVEIS NO EDITOR:
    - Imagem do produto
    - Cor de fundo imagem
    - Headline
    - Subtítulo
    - 4x Campos benefícios (text input)
    - Cor do checkmark
    - Texto do botão
    - Link do botão
    
    TECNOLOGIA:
    - Liquid puro
    - Usar variables.css do tema para cores
    - CSS inline na section ou schema
    - Sem dependência de JS externo
    
    OBJETIVO: Bloco reutilizável para home, editável no editor Shopify, sem alterar código existente., de a opção de posicionar o banner na esquerda ou na direita
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-hero-benefits-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  .ai-hero-benefits-container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: {% if block.settings.image_position == 'right' %}row-reverse{% else %}row{% endif %};
    width: 100%;
    gap: 0;
  }

  .ai-hero-benefits-image-column-{{ ai_gen_id }} {
    flex: 1;
    background-color: {{ block.settings.image_background_color }};
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 40px;
    {% if block.settings.image_position == 'right' %}
      border-top-left-radius: {{ block.settings.image_border_radius }}px;
    {% else %}
      border-top-right-radius: {{ block.settings.image_border_radius }}px;
    {% endif %}
  }

  .ai-hero-benefits-image-wrapper-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .ai-hero-benefits-image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    object-fit: cover;
  }

  .ai-hero-benefits-image-placeholder-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    min-height: 400px;
    display: flex;
    align-items: center;
    justify-content: center;
    background-color: rgba(0, 0, 0, 0.05);
  }

  .ai-hero-benefits-image-placeholder-{{ ai_gen_id }} svg {
    width: 100%;
    height: 100%;
    max-width: 300px;
    max-height: 300px;
  }

  .ai-hero-benefits-content-column-{{ ai_gen_id }} {
    flex: 1;
    display: flex;
    flex-direction: column;
    justify-content: center;
    padding: 60px;
    gap: 24px;
  }

  .ai-hero-benefits-headline-{{ ai_gen_id }} {
    font-size: 48px;
    font-weight: 700;
    line-height: 1.2;
    margin: 0;
    color: var(--color-foreground-heading);
  }

  .ai-hero-benefits-subtitle-{{ ai_gen_id }} {
    font-size: 18px;
    line-height: 1.5;
    color: #6d6d6d;
    margin: 0;
  }

  .ai-hero-benefits-list-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 12px;
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .ai-hero-benefits-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 12px;
    font-size: 16px;
    line-height: 1.5;
  }

  .ai-hero-benefits-checkmark-{{ ai_gen_id }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    color: {{ block.settings.checkmark_color }};
  }

  .ai-hero-benefits-cta-{{ ai_gen_id }} {
    margin-top: 8px;
  }

  @media screen and (max-width: 749px) {
    .ai-hero-benefits-container-{{ ai_gen_id }} {
      flex-direction: column;
    }

    .ai-hero-benefits-image-column-{{ ai_gen_id }} {
      border-top-right-radius: 0;
      border-top-left-radius: 0;
      padding: 30px;
    }

    .ai-hero-benefits-content-column-{{ ai_gen_id }} {
      padding: 40px 20px;
    }

    .ai-hero-benefits-headline-{{ ai_gen_id }} {
      font-size: 32px;
    }

    .ai-hero-benefits-subtitle-{{ ai_gen_id }} {
      font-size: 16px;
    }

    .ai-hero-benefits-item-{{ ai_gen_id }} {
      font-size: 14px;
    }
  }
{% endstyle %}

<div class="ai-hero-benefits-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-hero-benefits-container-{{ ai_gen_id }}">
    <div class="ai-hero-benefits-image-column-{{ ai_gen_id }}">
      <div class="ai-hero-benefits-image-wrapper-{{ ai_gen_id }}">
        {% if block.settings.product_image %}
          <img
            src="{{ block.settings.product_image | image_url: width: 1000 }}"
            alt="{{ block.settings.product_image.alt | escape }}"
            loading="lazy"
            width="{{ block.settings.product_image.width }}"
            height="{{ block.settings.product_image.height }}"
            class="ai-hero-benefits-image-{{ ai_gen_id }}"
          >
        {% else %}
          <div class="ai-hero-benefits-image-placeholder-{{ ai_gen_id }}">
            {{ 'product-1' | placeholder_svg_tag }}
          </div>
        {% endif %}
      </div>
    </div>

    <div class="ai-hero-benefits-content-column-{{ ai_gen_id }}">
      {% if block.settings.headline != blank %}
        <h2 class="ai-hero-benefits-headline-{{ ai_gen_id }}">{{ block.settings.headline }}</h2>
      {% endif %}

      {% if block.settings.subtitle != blank %}
        <p class="ai-hero-benefits-subtitle-{{ ai_gen_id }}">{{ block.settings.subtitle }}</p>
      {% endif %}

      <ul class="ai-hero-benefits-list-{{ ai_gen_id }}">
        {% if block.settings.benefit_1 != blank %}
          <li class="ai-hero-benefits-item-{{ ai_gen_id }}">
            <svg class="ai-hero-benefits-checkmark-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>{{ block.settings.benefit_1 }}</span>
          </li>
        {% endif %}

        {% if block.settings.benefit_2 != blank %}
          <li class="ai-hero-benefits-item-{{ ai_gen_id }}">
            <svg class="ai-hero-benefits-checkmark-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>{{ block.settings.benefit_2 }}</span>
          </li>
        {% endif %}

        {% if block.settings.benefit_3 != blank %}
          <li class="ai-hero-benefits-item-{{ ai_gen_id }}">
            <svg class="ai-hero-benefits-checkmark-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>{{ block.settings.benefit_3 }}</span>
          </li>
        {% endif %}

        {% if block.settings.benefit_4 != blank %}
          <li class="ai-hero-benefits-item-{{ ai_gen_id }}">
            <svg class="ai-hero-benefits-checkmark-{{ ai_gen_id }}" xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="20 6 9 17 4 12"></polyline>
            </svg>
            <span>{{ block.settings.benefit_4 }}</span>
          </li>
        {% endif %}
      </ul>

      {% if block.settings.button_text != blank %}
        <div class="ai-hero-benefits-cta-{{ ai_gen_id }}">
          <a href="{{ block.settings.button_link }}" class="button button--primary">
            {{ block.settings.button_text }}
          </a>
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Hero com benefícios",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "image_position",
      "label": "Posição da imagem",
      "options": [
        {
          "value": "left",
          "label": "Esquerda"
        },
        {
          "value": "right",
          "label": "Direita"
        }
      ],
      "default": "left"
    },
    {
      "type": "header",
      "content": "Imagem"
    },
    {
      "type": "image_picker",
      "id": "product_image",
      "label": "Imagem do produto"
    },
    {
      "type": "color",
      "id": "image_background_color",
      "label": "Cor de fundo",
      "default": "#f5f5f5"
    },
    {
      "type": "range",
      "id": "image_border_radius",
      "label": "Arredondamento do canto",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "px",
      "default": 20
    },
    {
      "type": "header",
      "content": "Conteúdo"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Título principal",
      "default": "Potencialize seus resultados"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Descubra os benefícios que vão transformar sua rotina"
    },
    {
      "type": "header",
      "content": "Benefícios"
    },
    {
      "type": "text",
      "id": "benefit_1",
      "label": "Benefício 1",
      "default": "Absorção rápida e eficiente"
    },
    {
      "type": "text",
      "id": "benefit_2",
      "label": "Benefício 2",
      "default": "Fórmula premium com ingredientes selecionados"
    },
    {
      "type": "text",
      "id": "benefit_3",
      "label": "Benefício 3",
      "default": "Resultados visíveis em poucas semanas"
    },
    {
      "type": "text",
      "id": "benefit_4",
      "label": "Benefício 4",
      "default": "Sabor incrível e refrescante"
    },
    {
      "type": "color",
      "id": "checkmark_color",
      "label": "Cor do checkmark",
      "default": "#0a84ff"
    },
    {
      "type": "header",
      "content": "Botão"
    },
    {
      "type": "text",
      "id": "button_text",
      "label": "Texto do botão",
      "default": "Comprar agora"
    },
    {
      "type": "url",
      "id": "button_link",
      "label": "Link do botão"
    }
  ],
  "presets": [
    {
      "name": "Hero com benefícios"
    }
  ]
}
{% endschema %}
