{%- doc -%}
  Renders a subscription upsell/status card for a cart line item.

  Hidden entirely when the line's variant has no selling plan available.
  Shows the ACTIVE state (already subscribed) when the line item carries a
  selling_plan_allocation, otherwise shows the OFFER state (one-time purchase
  that could switch to a subscription).

  @param {object} item - The cart line item (from cart.items).
  @param {number} line - The 1-based cart line number for this item.

  @example
  {% render 'cart-subscription-card', item: item, line: item.index | plus: 1 %}
{%- enddoc -%}

{%- liquid
  assign is_active = false
  assign plan_allocation = null

  if item.selling_plan_allocation
    assign is_active = true
    assign plan_allocation = item.selling_plan_allocation
  elsif item.variant.selling_plan_allocations.size > 0
    assign plan_allocation = item.variant.selling_plan_allocations.first
  endif
-%}

{% if plan_allocation %}
  <script
    src="{{ 'cart-subscription-card.js' | asset_url }}"
    type="module"
    fetchpriority="low"
  ></script>

  {%- liquid
    assign plan_price = plan_allocation.price
    assign plan_compare_at = plan_allocation.compare_at_price
    assign plan_savings = 0
    if plan_compare_at > plan_price
      assign plan_savings = plan_compare_at | minus: plan_price
    endif
  -%}

  <cart-subscription-card
    class="cart-subscription-card{% if is_active %} cart-subscription-card--active{% endif %}"
    data-line="{{ line }}"
    data-mode="{% if is_active %}active{% else %}offer{% endif %}"
    data-selling-plan-id="{{ plan_allocation.selling_plan.id }}"
  >
    <div class="cart-subscription-card__row">
      <div class="cart-subscription-card__text">
        <span class="cart-subscription-card__title">
          {% if is_active %}
            Assinatura Mensal ativa
          {% else %}
            Assine e economize
          {% endif %}
        </span>
        <span class="cart-subscription-card__price">
          {{ plan_price | money }}
          {% if plan_compare_at > plan_price %}
            <s>{{ plan_compare_at | money }}</s>
          {% endif %}
        </span>
        {% if plan_savings > 0 %}
          <span class="cart-subscription-card__savings">
            Economize {{ plan_savings | money }}
          </span>
        {% endif %}
      </div>

      <button
        type="button"
        class="cart-subscription-card__cta{% if is_active %} cart-subscription-card__cta--ghost{% endif %}"
        on:click="/toggle"
        ref="cta"
      >
        <span ref="ctaLabel">
          {% if is_active %}
            Trocar para compra única
          {% else %}
            Assinar e economizar
          {% endif %}
        </span>
      </button>
    </div>

    <p
      class="cart-subscription-card__error hidden"
      role="alert"
      ref="error"
    ></p>
  </cart-subscription-card>
{% endif %}

{% stylesheet %}
  .cart-subscription-card {
    display: block;
    width: 100%;
    background-color: var(--card-bg);
    border: var(--style-border-width) solid var(--brand-border);
    border-radius: var(--style-border-radius-buttons-primary);
    padding: var(--padding-sm) var(--padding-md);
  }

  .cart-subscription-card[busy] {
    opacity: 0.6;
    pointer-events: none;
  }

  .cart-subscription-card__row {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: var(--gap-md);
  }

  .cart-subscription-card__error {
    margin: var(--margin-2xs) 0 0;
    font-size: var(--font-size--xs);
    color: var(--color-error, #d02e2e);
  }

  .cart-subscription-card__error.hidden {
    display: none;
  }

  .cart-subscription-card__text {
    display: flex;
    flex-direction: column;
    gap: var(--gap-3xs, 2px);
    min-width: 0;
  }

  .cart-subscription-card__title {
    font-size: var(--font-size--sm);
    font-weight: var(--font-weight-bold);
    color: var(--text-dark);
  }

  .cart-subscription-card__price {
    font-size: var(--font-size--sm);
    color: var(--text-dark);
  }

  .cart-subscription-card__price s {
    opacity: 0.6;
    margin-inline-start: var(--margin-3xs, 4px);
  }

  .cart-subscription-card__savings {
    font-size: var(--font-size--xs);
    font-weight: var(--font-weight-bold);
    color: var(--brand-blue);
  }

  .cart-subscription-card__cta {
    flex-shrink: 0;
    background-color: var(--brand-blue);
    color: #ffffff;
    border: none;
    border-radius: var(--style-border-radius-pills, 999px);
    padding: var(--padding-2xs) var(--padding-md);
    font-size: var(--font-size--xs);
    font-weight: var(--font-weight-bold);
    cursor: pointer;
    white-space: nowrap;
    transition: filter var(--animation-speed) var(--animation-easing);
  }

  .cart-subscription-card__cta:hover {
    filter: brightness(0.92);
  }

  .cart-subscription-card--active {
    background-color: var(--brand-blue);
    border-color: var(--brand-blue);
  }

  .cart-subscription-card--active .cart-subscription-card__title,
  .cart-subscription-card--active .cart-subscription-card__price,
  .cart-subscription-card--active .cart-subscription-card__savings,
  .cart-subscription-card--active .cart-subscription-card__error {
    color: #ffffff;
  }

  .cart-subscription-card--active .cart-subscription-card__cta--ghost {
    background-color: transparent;
    color: #ffffff;
    border: var(--style-border-width) solid rgb(255 255 255 / 0.6);
  }

  .cart-subscription-card--active .cart-subscription-card__cta--ghost:hover {
    filter: none;
    background-color: rgb(255 255 255 / 0.15);
  }
{% endstylesheet %}
