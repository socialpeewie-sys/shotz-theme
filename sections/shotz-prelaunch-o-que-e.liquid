{% doc %}
  "O que é" section for the Shotz pre-launch landing page.
{% enddoc %}

<section class="spl-card-full spl-s3">
  <div class="spl-s3__bg">
    {% if section.settings.section3_image %}
      {{
        section.settings.section3_image
        | image_url: width: 2000
        | image_tag:
          loading: 'lazy',
          sizes: '(min-width: 1440px) 1440px, 100vw',
          widths: '750, 1100, 1500, 2000',
          class: 'spl-s3__media'
      }}
    {% else %}
      <div class="spl-hero__placeholder" aria-hidden="true">
        <span>foto: textura / produto</span>
      </div>
    {% endif %}
    <div class="spl-s3__overlay"></div>
  </div>

  <div class="spl-s3__content">
    <h2>Uma nova forma<br>de consumir proteína.</h2>

    <p class="spl-s3__intro">
      Shotz é um shot proteico criado para tornar o consumo de proteína mais simples, prático e parte da sua rotina.
    </p>

    <div class="spl-badge-row">
      {% assign checklist_items = 'Alta concentração de proteína|Apenas 100 ml|Zero açúcar|Zero gordura|Zero carboidratos|Zero lactose|Sabores frutados e refrescantes|20g de proteína por shot' | split: '|' %}
      {% for item in checklist_items %}
        <span class="spl-badge-pill">{{ item }}</span>
      {% endfor %}
    </div>

    <button
      type="button"
      class="spl-btn"
      data-spl-open-modal
    >
      Quero conhecer a Shotz <span class="spl-btn__arrow" aria-hidden="true">→</span>
    </button>
  </div>
</section>

{% schema %}
{
  "name": "Prelaunch — O que é",
  "settings": [
    {
      "type": "image_picker",
      "id": "section3_image",
      "label": "Imagem de fundo"
    }
  ]
}
{% endschema %}
