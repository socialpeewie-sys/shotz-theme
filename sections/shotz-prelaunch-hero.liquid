{% doc %}
  Hero section for the Shotz pre-launch landing page.
{% enddoc %}

<section class="spl-card-full spl-hero">
  <div class="spl-hero__bg">
    {% if section.settings.hero_video %}
      {{
        section.settings.hero_video
        | video_tag:
          image_size: '1500x',
          autoplay: true,
          loop: true,
          muted: true,
          controls: false,
          class: 'spl-hero__media'
      }}
    {% elsif section.settings.hero_image %}
      {{
        section.settings.hero_image
        | image_url: width: 2000
        | image_tag:
          loading: 'eager',
          fetchpriority: 'high',
          sizes: '(min-width: 1440px) 1440px, 100vw',
          widths: '750, 1100, 1500, 2000',
          class: 'spl-hero__media'
      }}
    {% else %}
      <div class="spl-hero__placeholder" aria-hidden="true">
        <span>foto ou vídeo: rotina / lifestyle</span>
      </div>
    {% endif %}
    <div class="spl-hero__overlay"></div>
  </div>

  <div class="spl-hero__content">
    <div class="spl-wordmark">SHOTZ</div>

    <h1 class="spl-hero__headline">Sua rotina já é complexa.<br>Consumir proteína não precisa ser.</h1>

    <p class="spl-hero__subheadline">
      Shotz é um shot proteico com 20g de proteína criado para tornar o consumo de proteína mais simples.
    </p>

    <p class="spl-tagline">
      <span class="spl-tagline__white">Pronto.</span>
      <span class="spl-tagline__accent">Prático.</span>
      <span class="spl-tagline__white">Proteico.</span>
    </p>

    <span class="spl-glass-pill">
      Cadastre-se para ter acesso antecipado ao lançamento e garanta 10% OFF na sua primeira compra.
    </span>

    <div>
      <button
        type="button"
        class="spl-btn"
        data-spl-open-modal
      >
        Quero acesso antecipado <span class="spl-btn__arrow" aria-hidden="true">→</span>
      </button>
    </div>

    <p class="spl-caption">Vagas limitadas</p>
  </div>
</section>

{% schema %}
{
  "name": "Prelaunch — Hero",
  "settings": [
    {
      "type": "video",
      "id": "hero_video",
      "label": "Vídeo de fundo",
      "info": "Se definido, tem prioridade sobre a foto de fundo abaixo."
    },
    {
      "type": "image_picker",
      "id": "hero_image",
      "label": "Foto de fundo",
      "info": "Usada quando nenhum vídeo é definido."
    }
  ]
}
{% endschema %}
