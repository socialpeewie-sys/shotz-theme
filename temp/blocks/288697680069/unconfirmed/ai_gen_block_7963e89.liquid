      "default": "#0a84ff"
    },
    {
      "type": "range",
      "id": "animation_speed",
      "min": 10,
      "max": 60,
      "step": 5,
      "unit": "s",
      "label": "Velocidade da animação",
      "default": 30,
      "info": "Tempo em segundos para completar uma volta"
    },
    {
