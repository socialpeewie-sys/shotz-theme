<style>
  .sz-mq {
    background-color: {{ section.settings.bg_color }};
    padding: 60px 0 70px;
    overflow: hidden;
  }
  .sz-mq__header {
    text-align: center;
    margin-bottom: 40px;
    padding: 0 20px;
  }
  .sz-mq__eyebrow {
    font-size: 11px;
    letter-spacing: 0.16em;
    text-transform: uppercase;
    color: {{ section.settings.accent_color }};
    margin-bottom: 10px;
  }
  .sz-mq__heading {
    font-size: clamp(26px, 4vw, 48px);
    font-weight: 800;
    color: #1a1a1a;
  }
  .sz-mq__wrapper {
    overflow: hidden;
    width: 100%;
  }
  .sz-mq__track {
    display: flex;
    gap: 16px;
    width: max-content;
    animation: sz-scroll linear infinite;
    animation-duration: {{ section.settings.speed }}s;
  }
  .sz-mq__track:hover {
    animation-play-state: paused;
  }
  @keyframes sz-scroll {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
  .sz-mq__card {
    position: relative;
    width: 280px;
    height: 360px;
    border-radius: 16px;
    overflow: hidden;
    flex-shrink: 0;
  }
  .sz-mq__card img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }
  .sz-mq__label {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    background: {{ section.settings.accent_color }};
    color: #fff;
    font-size: 14px;
    font-weight: 700;
    padding: 12px 16px;
  }
</style>

<section class="sz-mq">
  <div class="sz-mq__header">
    {% if section.settings.eyebrow != blank %}
      <p class="sz-mq__eyebrow">⚡ {{ section.settings.eyebrow }}</p>
    {% endif %}
    {% if section.settings.heading != blank %}
      <h2 class="sz-mq__heading">{{ section.settings.heading }}</h2>
    {% endif %}
  </div>

  <div class="sz-mq__wrapper">
    <div class="sz-mq__track">

      {% comment %} Loop original {% endcomment %}
      {% for block in section.blocks %}
        <div class="sz-mq__card" {{ block.shopify_attributes }}>
          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: width: 560 }}"
                 alt="{{ block.settings.label }}" loading="lazy">
          {% endif %}
          {% if block.settings.label != blank %}
            <div class="sz-mq__label">{{ block.settings.label }}</div>
          {% endif %}
        </div>
      {% endfor %}

      {% comment %} Duplicata para loop seamless {% endcomment %}
      {% for block in section.blocks %}
        <div class="sz-mq__card" aria-hidden="true">
          {% if block.settings.image %}
            <img src="{{ block.settings.image | image_url: width: 560 }}"
                 alt="" loading="lazy">
          {% endif %}
          {% if block.settings.label != blank %}
            <div class="sz-mq__label">{{ block.settings.label }}</div>
          {% endif %}
        </div>
      {% endfor %}

    </div>
  </div>
</section>

{% schema %}
{
  "name": "Shotz – Marquee",
  "settings": [
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow",
      "default": "Quando tomar"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Título",
      "default": "Energia pra rotina real."
    },
    {
      "type": "color",
      "id": "bg_color",
      "label": "Cor de fundo",
      "default": "#faf5ee"
    },
    {
      "type": "color",
      "id": "accent_color",
      "label": "Cor do label e eyebrow",
      "default": "#e07b2e"
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Velocidade (segundos para uma volta)",
      "min": 10,
      "max": 60,
      "step": 5,
      "default": 30
    }
  ],
  "blocks": [
    {
      "type": "slide",
      "name": "Imagem",
      "settings": [
        {
          "type": "image_picker",
          "id": "image",
          "label": "Foto"
        },
        {
          "type": "text",
          "id": "label",
          "label": "Label",
          "default": "Academia"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Shotz – Marquee",
      "blocks": [
        { "type": "slide", "settings": { "label": "Pré-treino" } },
        { "type": "slide", "settings": { "label": "Correria do dia" } },
        { "type": "slide", "settings": { "label": "Trabalho" } },
        { "type": "slide", "settings": { "label": "Lanche da tarde" } },
        { "type": "slide", "settings": { "label": "Academia" } }
      ]
    }
  ]
}
{% endschema %}