{% doc %}
  @prompt
    Create a new Shopify Liquid section called shotz-benefits with the following requirements:
    Layout: Dark full-width section (background-color: #0d0d0d) with a configurable background image centered behind the content at low opacity (around 0.35), used to display product photos. The background image should be uploaded via the theme customizer.
    Header block (all fields configurable in customizer):
    
    Eyebrow text (small uppercase label above the title)
    Main heading (large bold title)
    Subheading (shorter descriptive paragraph below the title)
    
    All header text should be white or near-white. Center-aligned.
    Cards block: Below the header, display a 3-column grid of benefit cards. Each card must be a block of type card so the merchant can add, remove, or reorder cards in the customizer. Each card has:
    
    Icon field (text input, accepts emoji)
    Title (bold, white)
    Description (smaller, muted white)
    
    Cards should have a semi-transparent frosted glass style: background: rgba(255,255,255,0.07), backdrop-filter: blur(12px), subtle white border, and border-radius: 16px. Text left-aligned inside cards.
    Responsive: On mobile (max-width 768px), stack cards in a single column and hide the background image.
    Schema: All settings (eyebrow, heading, subheading, background image) and all block settings (icon, title, description) must be editable via the Shopify theme customizer. Include a preset with 3 default cards already filled in.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .shotz-benefits-{{ ai_gen_id }} {
    position: relative;
    width: 100%;
    background-color: #0d0d0d;
    padding: 80px 20px;
    overflow: hidden;
  }

  .shotz-benefits-bg-{{ ai_gen_id }} {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    opacity: {{ block.settings.background_opacity | divided_by: 100.0 }};
    z-index: 0;
  }

  .shotz-benefits-bg-{{ ai_gen_id }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
  }

  .shotz-benefits-container-{{ ai_gen_id }} {
    position: relative;
    z-index: 1;
    max-width: 1200px;
    margin: 0 auto;
  }

  .shotz-benefits-header-{{ ai_gen_id }} {
    text-align: center;
    margin-bottom: 60px;
  }

  .shotz-benefits-eyebrow-{{ ai_gen_id }} {
    font-size: 12px;
    text-transform: uppercase;
    letter-spacing: 2px;
    color: {{ block.settings.text_color }};
    margin-bottom: 16px;
    opacity: 0.8;
  }

  .shotz-benefits-heading-{{ ai_gen_id }} {
    font-size: 48px;
    font-weight: 800;
    color: {{ block.settings.text_color }};
    margin: 0 0 20px;
    line-height: 1.2;
  }

  .shotz-benefits-subheading-{{ ai_gen_id }} {
    font-size: 18px;
    color: {{ block.settings.text_color }};
    opacity: 0.9;
    max-width: 600px;
    margin: 0 auto;
    line-height: 1.6;
  }

  .shotz-benefits-cards-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 24px;
  }

  .shotz-benefits-card-{{ ai_gen_id }} {
    background: rgba(255, 255, 255, 0.07);
    backdrop-filter: blur(12px);
    border: 1px solid rgba(255, 255, 255, 0.1);
    border-radius: 16px;
    padding: 32px 24px;
    text-align: left;
    transition: transform 0.3s ease, background 0.3s ease;
  }

  .shotz-benefits-card-{{ ai_gen_id }}:hover {
    transform: translateY(-4px);
    background: rgba(255, 255, 255, 0.1);
  }

  .shotz-benefits-card-icon-{{ ai_gen_id }} {
    font-size: 40px;
    margin-bottom: 16px;
    display: block;
  }

  .shotz-benefits-card-title-{{ ai_gen_id }} {
    font-size: 20px;
    font-weight: 700;
    color: {{ block.settings.text_color }};
    margin: 0 0 12px;
  }

  .shotz-benefits-card-description-{{ ai_gen_id }} {
    font-size: 14px;
    color: {{ block.settings.text_color }};
    opacity: 0.8;
    line-height: 1.6;
    margin: 0;
  }

  @media screen and (max-width: 768px) {
    .shotz-benefits-{{ ai_gen_id }} {
      padding: 60px 16px;
    }

    .shotz-benefits-heading-{{ ai_gen_id }} {
      font-size: 32px;
    }

    .shotz-benefits-subheading-{{ ai_gen_id }} {
      font-size: 16px;
    }

    .shotz-benefits-cards-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: 16px;
    }

    .shotz-benefits-header-{{ ai_gen_id }} {
      margin-bottom: 40px;
    }
  }
{% endstyle %}

<div class="shotz-benefits-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.background_image %}
    <div class="shotz-benefits-bg-{{ ai_gen_id }}">
      <img
        src="{{ block.settings.background_image | image_url: width: 2000 }}"
        alt="{{ block.settings.background_image.alt | escape }}"
        loading="lazy"
        width="{{ block.settings.background_image.width }}"
        height="{{ block.settings.background_image.height }}"
      >
    </div>
  {% endif %}

  <div class="shotz-benefits-container-{{ ai_gen_id }}">
    <div class="shotz-benefits-header-{{ ai_gen_id }}">
      {% if block.settings.eyebrow != blank %}
        <div class="shotz-benefits-eyebrow-{{ ai_gen_id }}">{{ block.settings.eyebrow }}</div>
      {% endif %}

      {% if block.settings.heading != blank %}
        <h2 class="shotz-benefits-heading-{{ ai_gen_id }}">{{ block.settings.heading }}</h2>
      {% endif %}

      {% if block.settings.subheading != blank %}
        <p class="shotz-benefits-subheading-{{ ai_gen_id }}">{{ block.settings.subheading }}</p>
      {% endif %}
    </div>

    <div class="shotz-benefits-cards-{{ ai_gen_id }}">
      {% if block.settings.card_1_icon != blank or block.settings.card_1_title != blank or block.settings.card_1_description != blank %}
        <div class="shotz-benefits-card-{{ ai_gen_id }}">
          {% if block.settings.card_1_icon != blank %}
            <span class="shotz-benefits-card-icon-{{ ai_gen_id }}">{{ block.settings.card_1_icon }}</span>
          {% endif %}

          {% if block.settings.card_1_title != blank %}
            <h3 class="shotz-benefits-card-title-{{ ai_gen_id }}">{{ block.settings.card_1_title }}</h3>
          {% endif %}

          {% if block.settings.card_1_description != blank %}
            <p class="shotz-benefits-card-description-{{ ai_gen_id }}">{{ block.settings.card_1_description }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.card_2_icon != blank or block.settings.card_2_title != blank or block.settings.card_2_description != blank %}
        <div class="shotz-benefits-card-{{ ai_gen_id }}">
          {% if block.settings.card_2_icon != blank %}
            <span class="shotz-benefits-card-icon-{{ ai_gen_id }}">{{ block.settings.card_2_icon }}</span>
          {% endif %}

          {% if block.settings.card_2_title != blank %}
            <h3 class="shotz-benefits-card-title-{{ ai_gen_id }}">{{ block.settings.card_2_title }}</h3>
          {% endif %}

          {% if block.settings.card_2_description != blank %}
            <p class="shotz-benefits-card-description-{{ ai_gen_id }}">{{ block.settings.card_2_description }}</p>
          {% endif %}
        </div>
      {% endif %}

      {% if block.settings.card_3_icon != blank or block.settings.card_3_title != blank or block.settings.card_3_description != blank %}
        <div class="shotz-benefits-card-{{ ai_gen_id }}">
          {% if block.settings.card_3_icon != blank %}
            <span class="shotz-benefits-card-icon-{{ ai_gen_id }}">{{ block.settings.card_3_icon }}</span>
          {% endif %}

          {% if block.settings.card_3_title != blank %}
            <h3 class="shotz-benefits-card-title-{{ ai_gen_id }}">{{ block.settings.card_3_title }}</h3>
          {% endif %}

          {% if block.settings.card_3_description != blank %}
            <p class="shotz-benefits-card-description-{{ ai_gen_id }}">{{ block.settings.card_3_description }}</p>
          {% endif %}
        </div>
      {% endif %}
    </div>
  </div>
</div>

{% schema %}
{
  "name": "Shotz benefits",
  "tag": null,
  "class": "shotz-benefits-section",
  "settings": [
    {
      "type": "header",
      "content": "Background"
    },
    {
      "type": "image_picker",
      "id": "background_image",
      "label": "Background image"
    },
    {
      "type": "range",
      "id": "background_opacity",
      "label": "Background opacity",
      "min": 0,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 35
    },
    {
      "type": "header",
      "content": "Header"
    },
    {
      "type": "text",
      "id": "eyebrow",
      "label": "Eyebrow text",
      "default": "Por que escolher"
    },
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "Benefícios do SHOTZ"
    },
    {
      "type": "textarea",
      "id": "subheading",
      "label": "Subheading",
      "default": "Proteína de alta qualidade em formato prático para o seu dia a dia"
    },
    {
      "type": "header",
      "content": "Colors"
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#ffffff"
    },
    {
      "type": "header",
      "content": "Card 1"
    },
    {
      "type": "text",
      "id": "card_1_icon",
      "label": "Icon",
      "default": "💪"
    },
    {
      "type": "text",
      "id": "card_1_title",
      "label": "Title",
      "default": "Alta proteína"
    },
    {
      "type": "textarea",
      "id": "card_1_description",
      "label": "Description",
      "default": "25g de proteína por shot para máxima recuperação muscular"
    },
    {
      "type": "header",
      "content": "Card 2"
    },
    {
      "type": "text",
      "id": "card_2_icon",
      "label": "Icon",
      "default": "⚡"
    },
    {
      "type": "text",
      "id": "card_2_title",
      "label": "Title",
      "default": "Energia rápida"
    },
    {
      "type": "textarea",
      "id": "card_2_description",
      "label": "Description",
      "default": "Absorção imediata para resultados quando você mais precisa"
    },
    {
      "type": "header",
      "content": "Card 3"
    },
    {
      "type": "text",
      "id": "card_3_icon",
      "label": "Icon",
      "default": "🎯"
    },
    {
      "type": "text",
      "id": "card_3_title",
      "label": "Title",
      "default": "Praticidade total"
    },
    {
      "type": "textarea",
      "id": "card_3_description",
      "label": "Description",
      "default": "Leve para qualquer lugar e consuma em segundos"
    }
  ],
  "presets": [
    {
      "name": "Shotz benefits"
    }
  ]
}
{% endschema %}
