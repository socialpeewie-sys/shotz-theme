{% doc %}
  @prompt
    quero 2 campos com "drop down" editáveis e que eu possa também incluir textos dentro do dropdown
    , na verdade quero que seja um menu de texto, onde ele fica fechado até o usuário clicar nele e abre o texto
    Exemplo: Ingredientes 
    Quando o usuário clicar em ingredientes, vai se abrir o dropdown com o texto com os ingredientes, queria ter a pção de colocar imagem também
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-accordion-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
  }

  .ai-accordion__container-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: {{ block.settings.item_spacing }}px;
  }

  .ai-accordion__item-{{ ai_gen_id }} {
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    border-radius: {{ block.settings.border_radius }}px;
    background-color: {{ block.settings.background_color }};
    overflow: hidden;
  }

  .ai-accordion__header-{{ ai_gen_id }} {
    width: 100%;
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.header_background }};
    border: none;
    cursor: pointer;
    text-align: left;
    transition: background-color 0.3s ease;
  }

  .ai-accordion__header-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.header_hover_background }};
  }

  .ai-accordion__title-{{ ai_gen_id }} {
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: {{ block.settings.title_color }};
    margin: 0;
  }

  .ai-accordion__icon-{{ ai_gen_id }} {
    width: 20px;
    height: 20px;
    transition: transform 0.3s ease;
    flex-shrink: 0;
    color: {{ block.settings.icon_color }};
  }

  .ai-accordion__item-{{ ai_gen_id }}.active .ai-accordion__icon-{{ ai_gen_id }} {
    transform: rotate(180deg);
  }

  .ai-accordion__content-{{ ai_gen_id }} {
    max-height: 0;
    overflow: hidden;
    transition: max-height 0.3s ease;
  }

  .ai-accordion__content-inner-{{ ai_gen_id }} {
    padding: 0 {{ block.settings.padding }}px {{ block.settings.padding }}px;
    font-size: {{ block.settings.content_size }}px;
    line-height: 1.6;
    color: {{ block.settings.content_color }};
  }

  .ai-accordion__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: 12px;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  .ai-accordion__item-{{ ai_gen_id }}.active .ai-accordion__content-{{ ai_gen_id }} {
    max-height: 2000px;
  }

  @media screen and (max-width: 749px) {
    .ai-accordion-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<accordion-menu-{{ ai_gen_id }}
  class="ai-accordion-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <div class="ai-accordion__container-{{ ai_gen_id }}">
    <div class="ai-accordion__item-{{ ai_gen_id }}" data-accordion-item>
      <button
        class="ai-accordion__header-{{ ai_gen_id }}"
        aria-expanded="false"
        type="button"
      >
        <h3 class="ai-accordion__title-{{ ai_gen_id }}">{{ block.settings.title_1 }}</h3>
        <svg
          class="ai-accordion__icon-{{ ai_gen_id }}"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <div class="ai-accordion__content-{{ ai_gen_id }}">
        <div class="ai-accordion__content-inner-{{ ai_gen_id }}">
          {% if block.settings.image_1 %}
            <img
              src="{{ block.settings.image_1 | image_url: width: 800 }}"
              alt="{{ block.settings.image_1.alt | escape }}"
              class="ai-accordion__image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.image_1.width }}"
              height="{{ block.settings.image_1.height }}"
            >
          {% endif %}
          {{ block.settings.content_1 }}
        </div>
      </div>
    </div>

    <div class="ai-accordion__item-{{ ai_gen_id }}" data-accordion-item>
      <button
        class="ai-accordion__header-{{ ai_gen_id }}"
        aria-expanded="false"
        type="button"
      >
        <h3 class="ai-accordion__title-{{ ai_gen_id }}">{{ block.settings.title_2 }}</h3>
        <svg
          class="ai-accordion__icon-{{ ai_gen_id }}"
          xmlns="http://www.w3.org/2000/svg"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
        >
          <polyline points="6 9 12 15 18 9"></polyline>
        </svg>
      </button>
      <div class="ai-accordion__content-{{ ai_gen_id }}">
        <div class="ai-accordion__content-inner-{{ ai_gen_id }}">
          {% if block.settings.image_2 %}
            <img
              src="{{ block.settings.image_2 | image_url: width: 800 }}"
              alt="{{ block.settings.image_2.alt | escape }}"
              class="ai-accordion__image-{{ ai_gen_id }}"
              loading="lazy"
              width="{{ block.settings.image_2.width }}"
              height="{{ block.settings.image_2.height }}"
            >
          {% endif %}
          {{ block.settings.content_2 }}
        </div>
      </div>
    </div>
  </div>
</accordion-menu-{{ ai_gen_id }}>

<script>
  (function() {
    class AccordionMenu{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }

      connectedCallback() {
        this.items = this.querySelectorAll('[data-accordion-item]');
        this.setupEventListeners();
      }

      setupEventListeners() {
        this.items.forEach((item) => {
          const header = item.querySelector('.ai-accordion__header-{{ ai_gen_id }}');
          const content = item.querySelector('.ai-accordion__content-{{ ai_gen_id }}');

          header.addEventListener('click', () => {
            const isActive = item.classList.contains('active');

            if (isActive) {
              item.classList.remove('active');
              header.setAttribute('aria-expanded', 'false');
            } else {
              item.classList.add('active');
              header.setAttribute('aria-expanded', 'true');
            }
          });
        });
      }
    }

    customElements.define('accordion-menu-{{ ai_gen_id }}', AccordionMenu{{ ai_gen_id }});
  })();
</script>

