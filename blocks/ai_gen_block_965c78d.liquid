{% doc %}
  @prompt
    ADICIONE OS CLAIMS "18g por garrafa" e "78 calorias"
    
    , utilize a fonte "Outfit" semi bold assim como no design do site
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-product-claims-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.gap }}px;
    align-items: center;
    justify-content: {{ block.settings.alignment }};
    width: {{ block.settings.desktop_width_percent }}%;
    flex-wrap: wrap;
  }

  .ai-product-claim-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    padding: {{ block.settings.padding }}px;
    background-color: {{ block.settings.background_color }};
    border-radius: {{ block.settings.border_radius }}px;
    border: {{ block.settings.border_width }}px solid {{ block.settings.border_color }};
    min-width: {{ block.settings.min_width }}px;
  }

  .ai-product-claim-value-{{ ai_gen_id }} {
    font-family: var(--font-heading-family);
    font-size: {{ block.settings.value_size }}px;
    font-weight: 600;
    color: {{ block.settings.value_color }};
    line-height: 1.2;
    margin: 0;
  }

  .ai-product-claim-label-{{ ai_gen_id }} {
    font-family: var(--font-body-family);
    font-size: {{ block.settings.label_size }}px;
    font-weight: 400;
    color: {{ block.settings.label_color }};
    line-height: 1.3;
    margin: 0;
    text-align: center;
  }

  @media screen and (max-width: 749px) {
    .ai-product-claims-{{ ai_gen_id }} {
      width: 100%;
    }
  }
{% endstyle %}

<div class="ai-product-claims-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  {% if block.settings.show_claim_1 %}
    <div class="ai-product-claim-{{ ai_gen_id }}">
      <div class="ai-product-claim-value-{{ ai_gen_id }}">{{ block.settings.claim_1_value }}</div>
      <div class="ai-product-claim-label-{{ ai_gen_id }}">{{ block.settings.claim_1_label }}</div>
    </div>
  {% endif %}

  {% if block.settings.show_claim_2 %}
    <div class="ai-product-claim-{{ ai_gen_id }}">
      <div class="ai-product-claim-value-{{ ai_gen_id }}">{{ block.settings.claim_2_value }}</div>
      <div class="ai-product-claim-label-{{ ai_gen_id }}">{{ block.settings.claim_2_label }}</div>
    </div>
  {% endif %}
</div>

{% schema %}
{
  "name": "Claims do produto",
  "settings": [
    {
      "type": "header",
      "content": "Claim 1"
    },
    {
      "type": "checkbox",
      "id": "show_claim_1",
      "label": "Mostrar claim 1",
      "default": true
    },
    {
      "type": "text",
      "id": "claim_1_value",
      "label": "Valor",
      "default": "18g"
    },
    {
      "type": "text",
      "id": "claim_1_label",
      "label": "Descrição",
      "default": "por garrafa"
    },
    {
      "type": "header",
      "content": "Claim 2"
    },
    {
      "type": "checkbox",
      "id": "show_claim_2",
      "label": "Mostrar claim 2",
      "default": true
    },
    {
      "type": "text",
      "id": "claim_2_value",
      "label": "Valor",
      "default": "78"
    },
    {
      "type": "text",
      "id": "claim_2_label",
      "label": "Descrição",
      "default": "calorias"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "select",
      "id": "alignment",
      "label": "Alinhamento",
      "options": [
        {
          "value": "flex-start",
          "label": "Esquerda"
        },
        {
          "value": "center",
          "label": "Centro"
        },
        {
          "value": "flex-end",
          "label": "Direita"
        }
      ],
      "default": "center"
    },
    {
      "type": "range",
      "id": "gap",
      "label": "Espaçamento entre claims",
      "min": 8,
      "max": 40,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "desktop_width_percent",
      "label": "Largura no desktop",
      "min": 50,
      "max": 100,
      "step": 5,
      "unit": "%",
      "default": 100
    },
    {
      "type": "header",
      "content": "Estilo dos claims"
    },
    {
      "type": "range",
      "id": "min_width",
      "label": "Largura mínima",
      "min": 80,
      "max": 200,
      "step": 10,
      "unit": "px",
      "default": 100
    },
    {
      "type": "range",
      "id": "padding",
      "label": "Espaçamento interno",
      "min": 8,
      "max": 32,
      "step": 4,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "border_radius",
      "label": "Arredondamento",
      "min": 0,
      "max": 32,
      "step": 2,
      "unit": "px",
      "default": 14
    },
    {
      "type": "range",
      "id": "border_width",
      "label": "Espessura da borda",
      "min": 0,
      "max": 4,
      "step": 1,
      "unit": "px",
      "default": 1
    },
    {
      "type": "color",
      "id": "background_color",
      "label": "Cor de fundo",
      "default": "#0094f60d"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Cor da borda",
      "default": "#0094f61c"
    },
    {
      "type": "header",
      "content": "Tipografia"
    },
    {
      "type": "range",
      "id": "value_size",
      "label": "Tamanho do valor",
      "min": 16,
      "max": 48,
      "step": 2,
      "unit": "px",
      "default": 24
    },
    {
      "type": "color",
      "id": "value_color",
      "label": "Cor do valor",
      "default": "#0094f6"
    },
    {
      "type": "range",
      "id": "label_size",
      "label": "Tamanho da descrição",
      "min": 10,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 12
    },
    {
      "type": "color",
      "id": "label_color",
      "label": "Cor da descrição",
      "default": "#000000cf"
    }
  ],
  "presets": [
    {
      "name": "Claims do produto"
    }
  ]
}
{% endschema %}
