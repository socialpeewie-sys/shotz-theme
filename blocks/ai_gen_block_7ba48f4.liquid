{% doc %}
  @prompt
    Seletor de sabores e quantidades para o tema Horizon da Shopify.
    Visual customizado que aciona o seletor nativo do Horizon para garantir
    que preço, imagem e título atualizem corretamente.
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-variant-selector-{{ ai_gen_id }} {
    display: block;
    width: 100%;
  }

  /* Esconde o seletor nativo — nosso bloco assume o visual */
  .variant-picker {
    display: none !important;
  }

  .ai-flavor-section-{{ ai_gen_id }} {
    margin-bottom: {{ block.settings.section_spacing }}px;
  }

  .ai-flavor-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.flavor_label_font_size }}px;
    font-weight: {{ block.settings.flavor_label_font_weight }};
    color: {{ block.settings.flavor_label_color }};
    margin-bottom: {{ block.settings.flavor_label_spacing }}px;
    display: {% if block.settings.show_flavor_label %}block{% else %}none{% endif %};
  }

  .ai-flavor-title-{{ ai_gen_id }} {
    display: none;
  }

  .ai-flavor-grid-{{ ai_gen_id }} {
    display: flex;
    gap: {{ block.settings.flavor_grid_gap }}px;
    flex-wrap: wrap;
    /* Reserva espaço para o outline (offset 2px + largura da borda selecionada + buffer) */
    padding: calc({{ block.settings.flavor_selected_border_width }}px + 4px);
  }

  .ai-flavor-item-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 6px;
  }

  .ai-flavor-card-{{ ai_gen_id }} {
    position: relative;
    width: {{ block.settings.flavor_thumbnail_size }}px;
    height: {{ block.settings.flavor_thumbnail_size }}px;
    border: {{ block.settings.flavor_border_width }}px solid {{ block.settings.flavor_border_color }};
    border-radius: {{ block.settings.flavor_border_radius }}px;
    overflow: hidden;
    cursor: pointer;
    /* outline cresce para fora (não afeta layout) — espaço reservado via padding no grid pai */
    outline: {{ block.settings.flavor_selected_border_width }}px solid transparent;
    outline-offset: 2px;
    transition: transform 0.22s cubic-bezier(0.34, 1.56, 0.64, 1),
                box-shadow 0.22s ease,
                outline-color 0.18s ease;
  }

  .ai-flavor-card-{{ ai_gen_id }}:hover {
    outline-color: {{ block.settings.flavor_hover_border_color }};
    /* scale removido: expande o card para fora do grid e clipa a borda esquerda do 1º card */
    transform: translateY(-4px);
    box-shadow: 0 10px 24px rgba(0, 148, 246, 0.2);
  }

  .ai-flavor-card-{{ ai_gen_id }}.selected {
    outline-color: {{ block.settings.flavor_selected_border_color }};
  }

  .ai-flavor-image-{{ ai_gen_id }} {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .ai-flavor-overlay-{{ ai_gen_id }} {
    font-size: {{ block.settings.overlay_font_size }}px;
    color: {{ block.settings.overlay_text_color }};
    text-align: center;
    width: {{ block.settings.flavor_thumbnail_size }}px;
    word-break: break-word;
    display: {% if block.settings.show_flavor_overlay %}block{% else %}none{% endif %};
  }

  .ai-flavor-checkmark-{{ ai_gen_id }} {
    position: absolute;
    top: {{ block.settings.checkmark_position }}px;
    right: {{ block.settings.checkmark_position }}px;
    width: {{ block.settings.checkmark_size }}px;
    height: {{ block.settings.checkmark_size }}px;
    background-color: {{ block.settings.checkmark_background }};
    border-radius: 50%;
    display: none;
    align-items: center;
    justify-content: center;
  }

  .ai-flavor-card-{{ ai_gen_id }}.selected .ai-flavor-checkmark-{{ ai_gen_id }} {
    display: flex;
  }

  .ai-flavor-checkmark-{{ ai_gen_id }} svg {
    width: 60%;
    height: 60%;
    fill: {{ block.settings.checkmark_icon_color }};
  }

  .ai-quantity-section-{{ ai_gen_id }} {
    margin-top: {{ block.settings.section_spacing }}px;
  }

  .ai-quantity-label-{{ ai_gen_id }} {
    font-size: {{ block.settings.quantity_label_font_size }}px;
    font-weight: {{ block.settings.quantity_label_font_weight }};
    color: {{ block.settings.quantity_label_color }};
    margin-bottom: {{ block.settings.quantity_label_spacing }}px;
    display: {% if block.settings.show_quantity_label %}block{% else %}none{% endif %};
  }

  .ai-quantity-grid-{{ ai_gen_id }} {
    display: grid;
    grid-template-columns: 1fr;
    gap: {{ block.settings.quantity_grid_gap }}px;
    /* Badge de desconto usa top: -11px — padding evita que seja clipado pelo container */
    padding-block-start: 14px;
  }

  @keyframes ai-select-bounce-{{ ai_gen_id }} {
    0%   { transform: scale(1); }
    35%  { transform: scale(0.93); }
    100% { transform: scale(1); }
  }

  .ai-quantity-card-{{ ai_gen_id }} {
    position: relative;
    padding: 14px 16px;
    border: {{ block.settings.quantity_card_border_width }}px solid {{ block.settings.quantity_card_border_color }};
    border-radius: {{ block.settings.quantity_card_border_radius }}px;
    background-color: {{ block.settings.quantity_card_background }};
    cursor: pointer;
    transition: background-color 0.2s ease,
                border-color 0.2s ease,
                box-shadow 0.2s ease;
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 12px;
    margin-top: 0;
  }

  /* ── Left: radio + label ── */
  .q-left-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 10px;
    flex: 1;
    min-width: 0;
  }
  .q-label-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    gap: 3px;
  }
  .q-row1-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: 6px;
    flex-wrap: wrap;
  }

  /* ── Right: prices ── */
  .q-right-{{ ai_gen_id }} {
    display: flex;
    flex-direction: column;
    align-items: flex-end;
    gap: 2px;
    flex-shrink: 0;
  }
  .q-compare-{{ ai_gen_id }} {
    font-size: 11px;
    font-weight: 400;
    color: rgb(150, 150, 150);
    text-decoration: line-through;
    line-height: 1.2;
  }
  .q-total-{{ ai_gen_id }} {
    font-size: {{ block.settings.quantity_price_font_size }}px;
    font-weight: 700;
    color: {{ block.settings.quantity_title_color }};
    line-height: 1.2;
  }

  .ai-quantity-card-{{ ai_gen_id }}:hover {
    background-color: {{ block.settings.quantity_card_hover_background }};
    border-color: {{ block.settings.quantity_card_hover_border_color }};
    box-shadow: 0 4px 12px rgba(0, 148, 246, 0.1);
  }

  .ai-quantity-card-{{ ai_gen_id }}.selected {
    background-color: {{ block.settings.quantity_card_selected_background }};
    border-color: {{ block.settings.quantity_card_selected_border_color }};
    border-width: {{ block.settings.quantity_card_selected_border_width }}px;
    animation: ai-select-bounce-{{ ai_gen_id }} 0.32s ease-out;
  }

  .ai-quantity-radio-{{ ai_gen_id }} {
    width: {{ block.settings.radio_size }}px;
    height: {{ block.settings.radio_size }}px;
    border: {{ block.settings.radio_border_width }}px solid {{ block.settings.radio_border_color }};
    border-radius: 50%;
    position: relative;
    transition: all 0.2s ease;
    flex-shrink: 0;
  }

  .ai-quantity-card-{{ ai_gen_id }}.selected .ai-quantity-radio-{{ ai_gen_id }} {
    border-color: {{ block.settings.radio_selected_border_color }};
    background-color: {{ block.settings.radio_selected_background }};
  }

  .ai-quantity-card-{{ ai_gen_id }}.selected .ai-quantity-radio-{{ ai_gen_id }}::after {
    content: '';
    position: absolute;
    top: 50%;
    left: 50%;
    transform: translate(-50%, -50%);
    width: 50%;
    height: 50%;
    background-color: {{ block.settings.radio_selected_dot_color }};
    border-radius: 50%;
  }

  .ai-quantity-title-{{ ai_gen_id }} {
    font-size: {{ block.settings.quantity_title_font_size }}px;
    font-weight: {{ block.settings.quantity_title_font_weight }};
    color: {{ block.settings.quantity_title_color }};
    text-align: left;
  }

  .ai-quantity-price-{{ ai_gen_id }} {
    font-size: {{ block.settings.quantity_price_font_size }}px;
    font-weight: {{ block.settings.quantity_price_font_weight }};
    color: {{ block.settings.quantity_price_color }};
    text-align: left;
  }

  /* Discount badge: floating top-right */
  .ai-quantity-badge-{{ ai_gen_id }} {
    position: absolute;
    top: -11px;
    right: 12px;
    left: auto;
    transform: none;
    padding: 3px 10px;
    border-radius: {{ block.settings.badge_border_radius }}px;
    font-size: {{ block.settings.badge_font_size }}px;
    font-weight: 700;
    white-space: nowrap;
    z-index: 1;
  }

  .ai-quantity-discount-badge-{{ ai_gen_id }} {
    background-color: {{ block.settings.discount_badge_background }};
    color: {{ block.settings.discount_badge_text }};
  }

  /* Shipping badge: inline inside label row */
  .ai-quantity-shipping-badge-{{ ai_gen_id }} {
    background-color: {{ block.settings.shipping_badge_background }};
    color: {{ block.settings.shipping_badge_text }};
    position: static;
    transform: none;
    display: inline-flex;
    align-items: center;
    padding: 2px 8px;
    font-size: {{ block.settings.shipping_badge_font_size }}px;
    border-radius: 4px;
    font-weight: 700;
    line-height: 1.3;
  }

  @media screen and (max-width: 749px) {
    .ai-flavor-card-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_flavor_thumbnail_size }}px;
      height: {{ block.settings.mobile_flavor_thumbnail_size }}px;
    }

    .ai-flavor-overlay-{{ ai_gen_id }} {
      width: {{ block.settings.mobile_flavor_thumbnail_size }}px;
    }

    .ai-quantity-grid-{{ ai_gen_id }} {
      grid-template-columns: 1fr;
      gap: {{ block.settings.mobile_quantity_grid_gap }}px;
    }

    .ai-quantity-card-{{ ai_gen_id }} {
      padding: {{ block.settings.mobile_quantity_card_padding }}px;
    }

    .ai-quantity-title-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_quantity_title_font_size }}px;
    }

    .ai-quantity-price-{{ ai_gen_id }} {
      font-size: {{ block.settings.mobile_quantity_price_font_size }}px;
    }
  }
{% endstyle %}

<variant-selector-{{ ai_gen_id }}
  class="ai-variant-selector-{{ ai_gen_id }}"
  data-product-id="{{ product.id }}"
  {{ block.shopify_attributes }}
>
  {%- comment -%} SELETOR DE SABOR {%- endcomment -%}
  <div class="ai-flavor-section-{{ ai_gen_id }}">
    {% if block.settings.flavor_label_text != blank %}
      <div class="ai-flavor-label-{{ ai_gen_id }}">{{ block.settings.flavor_label_text }}</div>
    {% endif %}

    <div class="ai-flavor-title-{{ ai_gen_id }}" data-flavor-title>
      {{ product.selected_or_first_available_variant.option1 | default: 'Selecione um sabor' }}
    </div>

    <div class="ai-flavor-grid-{{ ai_gen_id }}">
      {% assign flavors_added = '' %}
      {% for variant in product.variants %}
        {% assign variant_options = variant.title | split: ' / ' %}
        {% assign flavor = variant_options[0] %}
        {% unless flavors_added contains flavor %}
          {% assign flavors_added = flavors_added | append: flavor | append: ',' %}
          <div class="ai-flavor-item-{{ ai_gen_id }}">
            <div
              class="ai-flavor-card-{{ ai_gen_id }} {% if variant.option1 == product.selected_or_first_available_variant.option1 %}selected{% endif %}"
              data-flavor="{{ flavor }}"
              data-option1="{{ flavor }}"
            >
              {% if variant.featured_image %}
                <img src="{{ variant.featured_image | image_url: width: 200 }}" alt="{{ flavor }}" class="ai-flavor-image-{{ ai_gen_id }}" loading="lazy">
              {% elsif product.featured_image %}
                <img src="{{ product.featured_image | image_url: width: 200 }}" alt="{{ flavor }}" class="ai-flavor-image-{{ ai_gen_id }}" loading="lazy">
              {% endif %}
              <div class="ai-flavor-checkmark-{{ ai_gen_id }}">
                <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24">
                  <path d="M9 16.17L4.83 12l-1.42 1.41L9 19 21 7l-1.41-1.41L9 16.17z"/>
                </svg>
              </div>
            </div>
            <div class="ai-flavor-overlay-{{ ai_gen_id }}">{{ flavor }}</div>
          </div>
        {% endunless %}
      {% endfor %}
    </div>
  </div>

  {%- comment -%} SELETOR DE QUANTIDADE {%- endcomment -%}
  <div class="ai-quantity-section-{{ ai_gen_id }}">
    {% if block.settings.quantity_label_text != blank %}
      <div class="ai-quantity-label-{{ ai_gen_id }}">{{ block.settings.quantity_label_text }}</div>
    {% endif %}

    <div class="ai-quantity-grid-{{ ai_gen_id }}" data-quantity-grid>
      {% assign current_variant = product.selected_or_first_available_variant %}
      {% assign current_flavor = current_variant.option1 %}

      {% for variant in product.variants %}
        {% assign variant_flavor = variant.option1 %}
        {% assign variant_quantity = variant.option2 | default: variant.option1 %}

        {% if variant_flavor == current_flavor %}
          {% assign quantity_number = variant_quantity | remove: ' unidades' | remove: 'unidades' | strip | times: 1 %}
          {% assign unit_price = 0 %}
          {% if quantity_number > 0 %}
            {% assign unit_price = variant.price | divided_by: quantity_number %}
          {% endif %}

          {% assign discount_percent = 0 %}
          {% if variant.compare_at_price > variant.price %}
            {% assign price_diff = variant.compare_at_price | minus: variant.price %}
            {% assign discount_percent = price_diff | times: 100.0 | divided_by: variant.compare_at_price | round %}
          {% endif %}

          <div
            class="ai-quantity-card-{{ ai_gen_id }} {% if variant.id == current_variant.id %}selected{% endif %}"
            data-variant-id="{{ variant.id }}"
            data-option1="{{ variant.option1 }}"
            data-option2="{{ variant.option2 }}"
          >
            {%- comment -%} Badge de desconto — flutuante, canto superior direito {%- endcomment -%}
            {% if discount_percent > 0 %}
              <div class="ai-quantity-badge-{{ ai_gen_id }} ai-quantity-discount-badge-{{ ai_gen_id }}">
                {{ discount_percent }}% OFF
              </div>
            {% endif %}

            {%- comment -%} Seção esquerda: radio + labels {%- endcomment -%}
            <div class="q-left-{{ ai_gen_id }}">
              <div class="ai-quantity-radio-{{ ai_gen_id }}"></div>
              <div class="q-label-{{ ai_gen_id }}">
                <div class="q-row1-{{ ai_gen_id }}">
                  <span class="ai-quantity-title-{{ ai_gen_id }}">{{ variant_quantity }}</span>
                  {% if block.settings.free_shipping_min_qty > 0 and quantity_number >= block.settings.free_shipping_min_qty %}
                    <span class="ai-quantity-badge-{{ ai_gen_id }} ai-quantity-shipping-badge-{{ ai_gen_id }}">FRETE GRÁTIS</span>
                  {% endif %}
                </div>
                {% if unit_price > 0 %}
                  <div class="ai-quantity-price-{{ ai_gen_id }}">{{ unit_price | money }}/cada</div>
                {% endif %}
              </div>
            </div>

            {%- comment -%} Seção direita: preço original riscado + preço total {%- endcomment -%}
            <div class="q-right-{{ ai_gen_id }}">
              {% if variant.compare_at_price > variant.price %}
                <div class="q-compare-{{ ai_gen_id }}">{{ variant.compare_at_price | money }}</div>
              {% endif %}
              <div class="q-total-{{ ai_gen_id }}">{{ variant.price | money }}</div>
            </div>
          </div>
        {% endif %}
      {% endfor %}
    </div>
  </div>
</variant-selector-{{ ai_gen_id }}>

<script>
(function() {
  const id = '{{ ai_gen_id }}';
  const productVariants = {{ product.variants | json }};

  function formatMoney(cents) {
    return new Intl.NumberFormat('pt-BR', { style: 'currency', currency: 'BRL' }).format(cents / 100);
  }

  function triggerNativeRadio(optionValue) {
    const radios = document.querySelectorAll(
      `.variant-picker input[type="radio"][aria-label="${optionValue}"],
       .variant-picker input[type="radio"][value="${optionValue}"]`
    );
    radios.forEach(radio => {
      if (!radio.checked) {
        radio.checked = true;
        radio.dispatchEvent(new Event('change', { bubbles: true }));
        radio.dispatchEvent(new Event('input', { bubbles: true }));
      }
    });
  }

  function applyQuantitySelection(variantId) {
    document.querySelectorAll(`.ai-quantity-card-${id}`).forEach(c => {
      const isSelected = parseInt(c.dataset.variantId) === variantId;
      c.classList.toggle('selected', isSelected);
      c.style.borderColor = isSelected
        ? '{{ block.settings.quantity_card_selected_border_color }}'
        : '{{ block.settings.quantity_card_border_color }}';
      c.style.background = isSelected
        ? '{{ block.settings.quantity_card_selected_background }}'
        : '{{ block.settings.quantity_card_background }}';
      const radioEl = c.querySelector('.q-radio');
      if (radioEl) {
        radioEl.style.borderColor = isSelected
          ? '{{ block.settings.radio_selected_border_color }}'
          : '{{ block.settings.radio_border_color }}';
        radioEl.style.background = isSelected ? '{{ block.settings.radio_selected_background }}' : '#fff';
        radioEl.style.boxShadow = isSelected ? 'inset 0 0 0 3px #fff' : 'none';
      }
    });
  }

  function updateQuantityCards(flavor) {
    const grid = document.querySelector('[data-quantity-grid]');
    if (!grid) return;

    grid.innerHTML = '';

    const flavorVariants = productVariants.filter(v => v.option1 === flavor);
    const currentInput = document.querySelector('input[name="id"]');
    const currentId = currentInput ? parseInt(currentInput.value) : null;
    const selectedVariant = flavorVariants.find(v => v.id === currentId) || flavorVariants[0];

    flavorVariants.forEach(variant => {
      const qty = variant.option2 || variant.option1;
      const qtyNum = parseInt(qty.replace(/[^0-9]/g, '')) || 0;
      const unitPrice = qtyNum > 0 ? variant.price / qtyNum : 0;

      let discountPct = 0;
      if (variant.compare_at_price > variant.price) {
        discountPct = Math.round((variant.compare_at_price - variant.price) / variant.compare_at_price * 100);
      }

      const card = document.createElement('div');
      card.className = `ai-quantity-card-${id}`;
      card.dataset.variantId = variant.id;
      card.dataset.option1 = variant.option1;
      card.dataset.option2 = variant.option2 || '';
      card.style.cssText = 'position:relative;padding:14px 16px;border:{{ block.settings.quantity_card_border_width }}px solid {{ block.settings.quantity_card_border_color }};border-radius:{{ block.settings.quantity_card_border_radius }}px;background:{{ block.settings.quantity_card_background }};cursor:pointer;display:flex;flex-direction:row;align-items:center;justify-content:space-between;gap:12px;transition:all 0.2s;';

      let html = '';

      // Badge de desconto — flutuante, canto superior direito
      if (discountPct > 0) {
        html += `<div style="position:absolute;top:-11px;right:12px;left:auto;transform:none;background:{{ block.settings.discount_badge_background }};color:{{ block.settings.discount_badge_text }};font-size:{{ block.settings.badge_font_size }}px;font-weight:700;padding:3px 10px;border-radius:{{ block.settings.badge_border_radius }}px;white-space:nowrap;z-index:1;">${discountPct}% OFF</div>`;
      }

      // Seção esquerda: radio + labels
      html += `<div style="display:flex;align-items:center;gap:10px;flex:1;min-width:0;">`;
      html += `<div class="q-radio" style="width:{{ block.settings.radio_size }}px;height:{{ block.settings.radio_size }}px;border-radius:50%;border:{{ block.settings.radio_border_width }}px solid {{ block.settings.radio_border_color }};background:#fff;flex-shrink:0;transition:all 0.2s;"></div>`;
      html += `<div style="display:flex;flex-direction:column;gap:3px;">`;
      const freeShipMinQty = {{ block.settings.free_shipping_min_qty | default: 0 }};
      html += `<div style="display:flex;align-items:center;gap:6px;flex-wrap:wrap;">`;
      html += `<span style="font-size:{{ block.settings.quantity_title_font_size }}px;font-weight:{{ block.settings.quantity_title_font_weight }};color:{{ block.settings.quantity_title_color }};">${qty}</span>`;
      if (freeShipMinQty > 0 && qtyNum >= freeShipMinQty) {
        html += `<span style="background:{{ block.settings.shipping_badge_background }};color:{{ block.settings.shipping_badge_text }};display:inline-flex;align-items:center;padding:2px 8px;font-size:{{ block.settings.shipping_badge_font_size }}px;font-weight:700;border-radius:4px;line-height:1.3;">FRETE GRÁTIS</span>`;
      }
      html += `</div>`;
      if (unitPrice > 0) {
        html += `<div style="font-size:{{ block.settings.quantity_price_font_size }}px;font-weight:{{ block.settings.quantity_price_font_weight }};color:{{ block.settings.quantity_price_color }};">${formatMoney(unitPrice)}/cada</div>`;
      }
      html += `</div></div>`;

      // Seção direita: preço original riscado + preço total
      html += `<div style="display:flex;flex-direction:column;align-items:flex-end;gap:2px;flex-shrink:0;">`;
      if (variant.compare_at_price > variant.price) {
        html += `<div style="font-size:11px;font-weight:400;color:rgb(150,150,150);text-decoration:line-through;line-height:1.2;">${formatMoney(variant.compare_at_price)}</div>`;
      }
      html += `<div style="font-size:{{ block.settings.quantity_price_font_size }}px;font-weight:700;color:{{ block.settings.quantity_title_color }};line-height:1.2;">${formatMoney(variant.price)}</div>`;
      html += `</div>`;

      card.innerHTML = html;
      grid.appendChild(card);
    });

    if (selectedVariant) applyQuantitySelection(selectedVariant.id);
  }

  function selectFlavor(card) {
    document.querySelectorAll(`.ai-flavor-card-${id}`).forEach(c => c.classList.remove('selected'));
    card.classList.add('selected');

    const flavor = card.dataset.option1;
    const titleEl = document.querySelector('[data-flavor-title]');
    if (titleEl) titleEl.textContent = flavor;

    triggerNativeRadio(flavor);

    // Aguarda Horizon atualizar input[name="id"] antes de reconstruir os cards
    setTimeout(() => {
      updateQuantityCards(flavor);
      const firstCard = document.querySelector(`.ai-quantity-card-${id}`);
      if (firstCard) triggerNativeRadio(firstCard.dataset.option2);
    }, 0);
  }

  function selectQuantity(card) {
    const variantId = parseInt(card.dataset.variantId);
    applyQuantitySelection(variantId);
    triggerNativeRadio(card.dataset.option2);
    // Re-sincroniza visual após qualquer atualização assíncrona do Horizon
    requestAnimationFrame(() => applyQuantitySelection(variantId));
  }

  function setup() {
    document.querySelectorAll(`.ai-flavor-card-${id}`).forEach(card => {
      card.addEventListener('click', () => selectFlavor(card));
    });

    // Event delegation no grid — persiste após reconstrução dos cards
    const grid = document.querySelector('[data-quantity-grid]');
    if (grid) {
      grid.addEventListener('click', e => {
        const card = e.target.closest(`.ai-quantity-card-${id}`);
        if (card) selectQuantity(card);
      });
    }
  }

  if (document.readyState === 'loading') {
