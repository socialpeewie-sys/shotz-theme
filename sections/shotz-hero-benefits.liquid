{% assign sid = section.id | replace: '_', '' | downcase %}

{% style %}
  #shopify-section-{{ section.id }} {
    padding-block: {{ section.settings.section_padding }}px;
  }

  .shb-wrap-{{ sid }} {
    display: flex;
    flex-direction: row;
    align-items: stretch;
    border-radius: {{ section.settings.card_radius }}px;
    overflow: hidden;
    background: {{ section.settings.content_bg }};
    min-height: {{ section.settings.min_height }}px;
    max-width: {{ section.settings.max_width }}px;
    margin-inline: auto;
  }

  .shb-image-col-{{ sid }} {
    flex: 0 0 50%;
    background-color: {{ section.settings.image_bg }};
    position: relative;
    overflow: hidden;
  }

  .shb-image-col-{{ sid }} img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .shb-image-col-{{ sid }} .shb-placeholder-{{ sid }} {
    width: 100%;
    height: 100%;
    min-height: {{ section.settings.min_height }}px;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .shb-image-col-{{ sid }} .shb-placeholder-{{ sid }} svg {
    width: 55%;
    height: auto;
    opacity: 0.25;
  }

  .shb-content-col-{{ sid }} {
    flex: 0 0 50%;
    padding: {{ section.settings.content_padding }}px;
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .shb-headline-{{ sid }} {
    font-family: var(--font-heading--family);
    font-size: {{ section.settings.headline_size }}px;
    font-weight: 700;
    color: {{ section.settings.headline_color }};
    line-height: 1.2;
    margin: 0 0 12px 0;
  }

  .shb-subtitle-{{ sid }} {
    font-family: var(--font-body--family);
    font-size: {{ section.settings.subtitle_size }}px;
    color: {{ section.settings.subtitle_color }};
    line-height: 1.5;
    margin: 0 0 24px 0;
    white-space: pre-line;
  }

  .shb-benefits-{{ sid }} {
    list-style: none;
    margin: 0 0 28px 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 12px;
  }

  .shb-benefit-{{ sid }} {
    display: flex;
    align-items: flex-start;
    gap: 10px;
    font-family: var(--font-body--family);
    font-size: {{ section.settings.benefit_size }}px;
    color: {{ section.settings.benefit_color }};
    line-height: 1.4;
  }

  .shb-check-{{ sid }} {
    flex-shrink: 0;
    width: 20px;
    height: 20px;
    background-color: {{ section.settings.checkmark_color }};
    border-radius: 50%;
    display: flex;
    align-items: center;
    justify-content: center;
    margin-top: 1px;
  }

  .shb-check-{{ sid }} svg {
    width: 11px;
    height: 11px;
  }

  .shb-btn-{{ sid }} {
    align-self: flex-start;
  }

  @media screen and (max-width: 749px) {
    .shb-wrap-{{ sid }} {
      flex-direction: column;
      min-height: unset;
    }

    .shb-image-col-{{ sid }} {
      flex: none;
      height: {{ section.settings.mobile_image_height }}px;
    }

    .shb-image-col-{{ sid }} .shb-placeholder-{{ sid }} {
      min-height: {{ section.settings.mobile_image_height }}px;
    }

    .shb-content-col-{{ sid }} {
      flex: none;
      padding: {{ section.settings.content_padding | times: 0.65 | round }}px;
    }

    .shb-headline-{{ sid }} {
      font-size: {{ section.settings.headline_size | times: 0.75 | round }}px;
    }
  }
{% endstyle %}

<div class="shb-wrap-{{ sid }}">

  {%- comment -%} Coluna esquerda: imagem {%- endcomment -%}
  <div class="shb-image-col-{{ sid }}">
    {%- if section.settings.image != blank -%}
      {{
        section.settings.image
        | image_url: width: 1200
        | image_tag:
          loading: 'lazy',
          alt: section.settings.image.alt | escape,
          widths: '400, 600, 800, 1200'
      }}
    {%- else -%}
      <div class="shb-placeholder-{{ sid }}">
        {{ 'product-1' | placeholder_svg_tag }}
      </div>
    {%- endif -%}
  </div>

  {%- comment -%} Coluna direita: conteúdo {%- endcomment -%}
  <div class="shb-content-col-{{ sid }}">

    {%- if section.settings.headline != blank -%}
      <h2 class="shb-headline-{{ sid }}">{{ section.settings.headline }}</h2>
    {%- endif -%}

    {%- if section.settings.subtitle != blank -%}
      <p class="shb-subtitle-{{ sid }}">{{ section.settings.subtitle }}</p>
    {%- endif -%}

    {%- assign has_benefits = false -%}
    {%- for i in (1..4) -%}
      {%- assign bkey = 'benefit_' | append: i -%}
      {%- if section.settings[bkey] != blank -%}
        {%- assign has_benefits = true -%}
        {%- break -%}
      {%- endif -%}
    {%- endfor -%}

    {%- if has_benefits -%}
      <ul class="shb-benefits-{{ sid }}">
        {%- for i in (1..4) -%}
          {%- assign bkey = 'benefit_' | append: i -%}
          {%- if section.settings[bkey] != blank -%}
            <li class="shb-benefit-{{ sid }}">
              <span class="shb-check-{{ sid }}" aria-hidden="true">
                <svg viewBox="0 0 11 9" fill="none">
                  <path d="M1 4.5L4 7.5L10 1.5" stroke="#ffffff" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round"/>
                </svg>
              </span>
              <span>{{ section.settings[bkey] | escape }}</span>
            </li>
          {%- endif -%}
        {%- endfor -%}
      </ul>
    {%- endif -%}

    {%- if section.settings.btn_text != blank -%}
      <div class="shb-btn-{{ sid }}">
        <a
          href="{{ section.settings.btn_link | default: '#' }}"
          class="{{ section.settings.btn_style }}"
        >
          {{ section.settings.btn_text | escape }}
        </a>
      </div>
    {%- endif -%}

  </div>
</div>

{% schema %}
{
  "name": "Hero com Benefícios",
  "settings": [
    {
      "type": "header",
      "content": "Imagem"
    },
    {
      "type": "image_picker",
      "id": "image",
      "label": "Imagem do produto"
    },
    {
      "type": "color",
      "id": "image_bg",
      "label": "Cor de fundo da imagem",
      "default": "#ede4d6"
    },
    {
      "type": "range",
      "id": "min_height",
      "label": "Altura mínima (desktop)",
      "min": 200,
      "max": 700,
      "step": 20,
      "unit": "px",
      "default": 420
    },
    {
      "type": "range",
      "id": "mobile_image_height",
      "label": "Altura da imagem (mobile)",
      "min": 150,
      "max": 500,
      "step": 10,
      "unit": "px",
      "default": 260
    },
    {
      "type": "header",
      "content": "Título"
    },
    {
      "type": "text",
      "id": "headline",
      "label": "Headline",
      "default": "Por que escolher Shotz?"
    },
    {
      "type": "range",
      "id": "headline_size",
      "label": "Tamanho da fonte",
      "min": 20,
      "max": 60,
      "step": 2,
      "unit": "px",
      "default": 36
    },
    {
      "type": "color",
      "id": "headline_color",
      "label": "Cor do título",
      "default": "#000000"
    },
    {
      "type": "header",
      "content": "Subtítulo"
    },
    {
      "type": "textarea",
      "id": "subtitle",
      "label": "Subtítulo",
      "default": "Desenvolvido para quem leva performance a sério."
    },
    {
      "type": "range",
      "id": "subtitle_size",
      "label": "Tamanho da fonte",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "default": 16
    },
    {
      "type": "color",
      "id": "subtitle_color",
      "label": "Cor do subtítulo",
      "default": "#6d6d6d"
    },
    {
      "type": "header",
      "content": "Benefícios"
    },
    {
      "type": "text",
      "id": "benefit_1",
      "label": "Benefício 1",
      "default": "Fórmula desenvolvida com nutricionistas"
    },
    {
      "type": "text",
      "id": "benefit_2",
      "label": "Benefício 2",
      "default": "Sem açúcar, sem corantes artificiais"
    },
    {
      "type": "text",
      "id": "benefit_3",
      "label": "Benefício 3",
      "default": "Entrega rápida para todo o Brasil"
    },
    {
      "type": "text",
      "id": "benefit_4",
      "label": "Benefício 4",
      "default": ""
    },
    {
      "type": "range",
      "id": "benefit_size",
      "label": "Tamanho do texto",
      "min": 12,
      "max": 20,
      "step": 1,
      "unit": "px",
      "default": 15
    },
    {
      "type": "color",
      "id": "benefit_color",
      "label": "Cor do texto",
      "default": "#333333"
    },
    {
      "type": "color",
      "id": "checkmark_color",
      "label": "Cor do checkmark",
      "default": "#0a84ff"
    },
    {
      "type": "header",
      "content": "Botão CTA"
    },
    {
      "type": "text",
      "id": "btn_text",
      "label": "Texto do botão",
      "default": "Comprar agora"
    },
    {
      "type": "url",
      "id": "btn_link",
      "label": "Link do botão"
    },
    {
      "type": "select",
      "id": "btn_style",
      "label": "Estilo do botão",
      "options": [
        { "value": "button", "label": "Primário" },
        { "value": "button-secondary", "label": "Secundário" }
      ],
      "default": "button"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "color",
      "id": "content_bg",
      "label": "Cor de fundo do conteúdo",
      "default": "#ffffff"
    },
    {
      "type": "range",
      "id": "content_padding",
      "label": "Padding interno (conteúdo)",
      "min": 16,
      "max": 80,
      "step": 4,
      "unit": "px",
      "default": 48
    },
    {
      "type": "range",
      "id": "card_radius",
      "label": "Arredondamento do card",
      "min": 0,
      "max": 40,
      "step": 2,
      "unit": "px",
      "default": 16
    },
    {
      "type": "range",
      "id": "max_width",
      "label": "Largura máxima",
      "min": 600,
      "max": 1600,
      "step": 40,
      "unit": "px",
      "default": 1200
    },
    {
      "type": "range",
      "id": "section_padding",
      "label": "Espaçamento da seção",
      "min": 0,
      "max": 100,
      "step": 4,
      "unit": "px",
      "default": 40
    }
  ],
  "presets": [
    {
      "name": "Hero com Benefícios"
    }
  ]
}
{% endschema %}
