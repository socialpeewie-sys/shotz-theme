        {%- if section.settings.image_3 != blank -%}
          <div class="shotz-marquee__image">
            {{ section.settings.image_3 | image_url: width: 560 | image_tag: loading: 'lazy', widths: '280, 560', sizes: '280px' }}
          </div>
        {%- else -%}
          <div class="shotz-marquee__image shotz-marquee__placeholder">
            {{ 'product-3' | placeholder_svg_tag: 'placeholder-svg' }}
          </div>
        {%- endif -%}
        {%- if section.settings.label_3 != blank -%}
          <div class="shotz-marquee__label" style="background-color: {{ label_color }};">
