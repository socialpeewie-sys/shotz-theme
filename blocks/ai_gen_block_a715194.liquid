{% doc %}
  @prompt
    quero 2 campos com "drop down" editáveis e que eu possa também incluir textos dentro do dropdown
    , na verdade quero que seja um menu de texto, onde ele fica fechado até o usuário clicar nele e abre o texto
    Exemplo: Ingredientes
    Quando o usuário clicar em ingredientes, vai se abrir o dropdown com o texto com os ingredientes, queria ter a pção de colocar imagem também
{% enddoc %}
{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-tabs-{{ ai_gen_id }} {
    display: block;
    width: {{ block.settings.desktop_width_percent }}%;
    max-width: 100%;
    font-family: var(--font-paragraph--family, 'Plus Jakarta Sans', sans-serif);
  }

  /* ---- Segmented control container ---- */
  .ai-tabs__nav-{{ ai_gen_id }} {
    display: flex;
    flex-direction: row;
    align-items: center;
    background: rgba(0, 0, 0, 0.06);
    border-radius: var(--style-border-radius-buttons-primary, 14px);
    padding: 4px;
    gap: 2px;
    overflow-x: auto;
    -webkit-overflow-scrolling: touch;
    scrollbar-width: none;
    margin-bottom: 16px;
  }

  .ai-tabs__nav-{{ ai_gen_id }}::-webkit-scrollbar {
    display: none;
  }

  /* ---- Each tab = pill button ---- */
  .ai-tabs__tab-{{ ai_gen_id }} {
    flex: none;
    padding: 9px 16px;
    background: transparent;
    border: none;
    border-radius: calc(var(--style-border-radius-buttons-primary, 14px) - 2px);
    cursor: pointer;
    text-align: center;
    white-space: nowrap;
    font-family: var(--font-paragraph--family, 'Plus Jakarta Sans', sans-serif);
    font-size: {{ block.settings.title_size }}px;
    font-weight: {{ block.settings.title_weight }};
    color: var(--color-foreground, {{ block.settings.title_color }});
    letter-spacing: 0.01em;
    transition: background 0.18s ease, box-shadow 0.18s ease, color 0.18s ease;
  }

  .ai-tabs__tab-{{ ai_gen_id }}:hover:not(.active) {
    background: rgba(255, 255, 255, 0.45);
  }

  .ai-tabs__tab-{{ ai_gen_id }}.active {
    background: #ffffff;
    box-shadow: 0 1px 5px rgba(0, 0, 0, 0.14), 0 0 0 0.5px rgba(0, 0, 0, 0.06);
    color: {{ block.settings.title_color }};
    font-weight: {{ block.settings.title_weight | plus: 100 }};
  }

  /* ---- Content panels ---- */
  .ai-tabs__panel-{{ ai_gen_id }} {
    display: none;
    padding: {{ block.settings.padding }}px;
    font-family: var(--font-paragraph--family, 'Plus Jakarta Sans', sans-serif);
    font-size: {{ block.settings.content_size }}px;
    line-height: 1.7;
    color: {{ block.settings.content_color }};
    background-color: {{ block.settings.background_color }};
    border: {{ block.settings.border_width }}px solid rgba(0, 0, 0, 0.07);
    border-radius: var(--style-border-radius-buttons-primary, 14px);
  }

  .ai-tabs__panel-{{ ai_gen_id }}.active {
    display: block;
  }

  .ai-tabs__image-{{ ai_gen_id }} {
    width: 100%;
    height: auto;
    display: block;
    margin-bottom: 12px;
    border-radius: {{ block.settings.image_border_radius }}px;
  }

  @media screen and (max-width: 749px) {
    .ai-tabs-{{ ai_gen_id }} {
      width: 100%;
    }

    /* Scroll horizontal suave — abas nunca quebram linha */
    .ai-tabs__nav-{{ ai_gen_id }} {
      flex-wrap: nowrap;
      border-radius: 12px;
    }

    .ai-tabs__tab-{{ ai_gen_id }} {
      font-size: {{ block.settings.title_size | minus: 1 }}px;
      padding: 8px 14px;
    }
  }
{% endstyle %}

<accordion-menu-{{ ai_gen_id }}
  class="ai-tabs-{{ ai_gen_id }}"
  {{ block.shopify_attributes }}
>
  <!-- Tab navigation -->
  <div class="ai-tabs__nav-{{ ai_gen_id }}" role="tablist">
    <button
      class="ai-tabs__tab-{{ ai_gen_id }} active"
      role="tab"
      aria-selected="true"
      data-tab="0"
      type="button"
    >{{ block.settings.title_1 }}</button>
    <button
      class="ai-tabs__tab-{{ ai_gen_id }}"
      role="tab"
      aria-selected="false"
      data-tab="1"
      type="button"
    >{{ block.settings.title_2 }}</button>
    <button
      class="ai-tabs__tab-{{ ai_gen_id }}"
      role="tab"
      aria-selected="false"
      data-tab="2"
      type="button"
    >{{ block.settings.title_3 }}</button>
  </div>

  <!-- Panel 1 -->
  <div class="ai-tabs__panel-{{ ai_gen_id }} active" role="tabpanel" data-panel="0">
    {% if block.settings.image_1 %}
      <img
        src="{{ block.settings.image_1 | image_url: width: 800 }}"
        alt="{{ block.settings.image_1.alt | escape }}"
        class="ai-tabs__image-{{ ai_gen_id }}"
        loading="lazy"
        width="{{ block.settings.image_1.width }}"
        height="{{ block.settings.image_1.height }}"
      >
    {% endif %}
    {{ block.settings.content_1 }}
  </div>

  <!-- Panel 2 -->
  <div class="ai-tabs__panel-{{ ai_gen_id }}" role="tabpanel" data-panel="1">
    {% if block.settings.image_2 %}
      <img
        src="{{ block.settings.image_2 | image_url: width: 800 }}"
        alt="{{ block.settings.image_2.alt | escape }}"
        class="ai-tabs__image-{{ ai_gen_id }}"
        loading="lazy"
        width="{{ block.settings.image_2.width }}"
        height="{{ block.settings.image_2.height }}"
      >
    {% endif %}
    {{ block.settings.content_2 }}
  </div>

  <!-- Panel 3 -->
  <div class="ai-tabs__panel-{{ ai_gen_id }}" role="tabpanel" data-panel="2">
    {% if block.settings.image_3 %}
      <img
        src="{{ block.settings.image_3 | image_url: width: 800 }}"
        alt="{{ block.settings.image_3.alt | escape }}"
        class="ai-tabs__image-{{ ai_gen_id }}"
        loading="lazy"
        width="{{ block.settings.image_3.width }}"
        height="{{ block.settings.image_3.height }}"
      >
    {% endif %}
    {{ block.settings.content_3 }}
  </div>
</accordion-menu-{{ ai_gen_id }}>

<script>
  (function() {
    class AccordionMenu{{ ai_gen_id }} extends HTMLElement {
      connectedCallback() {
        this.tabs   = Array.from(this.querySelectorAll('.ai-tabs__tab-{{ ai_gen_id }}'));
        this.panels = Array.from(this.querySelectorAll('.ai-tabs__panel-{{ ai_gen_id }}'));
        this.tabs.forEach((tab, i) => {
          tab.addEventListener('click', () => this.#activate(i));
        });
      }

      #activate(index) {
        this.tabs.forEach((t, i) => {
          const active = i === index;
          t.classList.toggle('active', active);
          t.setAttribute('aria-selected', active ? 'true' : 'false');
        });
        this.panels.forEach((p, i) => p.classList.toggle('active', i === index));
      }
    }

    if (!customElements.get('accordion-menu-{{ ai_gen_id }}')) {
      customElements.define('accordion-menu-{{ ai_gen_id }}', AccordionMenu{{ ai_gen_id }});
    }
  })();
</script>

