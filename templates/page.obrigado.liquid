{% layout none %}
{% assign whatsapp_group_link = 'COLE_O_LINK_DO_GRUPO_AQUI' %}
<!doctype html>
<html lang="{{ request.locale.iso_code }}">
  <head>
    {%- render 'meta-tags' -%}

    {%- if settings.favicon != blank -%}
      <link
        rel="icon"
        type="image/png"
        href="{{ settings.favicon | image_url: width: 32, height: 32 }}"
      >
    {%- endif -%}

    {%- render 'fonts' -%}
    {%- render 'theme-styles-variables' -%}

    {{ 'shotz-prelaunch.css' | asset_url | stylesheet_tag }}

    {{ content_for_header }}
  </head>

  <body class="shotz-prelaunch">
    <div class="spl-thanks">
      <div class="spl-card spl-thanks__card">
        <div class="spl-thanks__icon">&#10003;</div>

        <h1>Você está na lista! 🎉</h1>
        <p class="spl-thanks__subtitle">
          Cadastro confirmado. Em breve você será o primeiro a saber quando o Lote 001 abrir.
        </p>

        <hr class="spl-thanks__divider">

        <p>
          Enquanto isso, entra no nosso grupo exclusivo do WhatsApp e acompanha os bastidores da Shotz.
        </p>

        <a
          href="{{ whatsapp_group_link }}"
          target="_blank"
          rel="noopener"
          class="spl-btn spl-btn--whatsapp"
        >
          <svg
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="currentColor"
            aria-hidden="true"
          >
            <path d="M12.04 2c-5.52 0-10 4.48-10 10 0 1.76.46 3.48 1.34 5L2 22l5.14-1.35a10 10 0 0 0 4.9 1.25h.01c5.52 0 10-4.48 10-10s-4.48-10-10-10zm0 18.15a8.14 8.14 0 0 1-4.15-1.14l-.3-.18-3.05.8.82-2.97-.2-.31a8.15 8.15 0 1 1 6.88 3.8zm4.47-6.1c-.24-.12-1.45-.72-1.68-.8-.22-.08-.39-.12-.55.12-.16.24-.63.8-.78.96-.14.16-.29.18-.53.06-.24-.12-1.02-.38-1.94-1.2-.72-.64-1.2-1.43-1.34-1.67-.14-.24-.02-.37.11-.49.11-.11.24-.29.36-.43.12-.14.16-.24.24-.4.08-.16.04-.3-.02-.42-.06-.12-.55-1.33-.76-1.82-.2-.48-.4-.42-.55-.42-.14 0-.3-.02-.46-.02-.16 0-.42.06-.64.3-.22.24-.84.82-.84 2s.86 2.32.98 2.48c.12.16 1.7 2.6 4.13 3.64.58.25 1.03.4 1.38.51.58.18 1.11.16 1.53.1.47-.07 1.45-.59 1.65-1.16.2-.57.2-1.06.14-1.16-.06-.1-.22-.16-.46-.28z"/>
          </svg>
          Entrar no grupo exclusivo
        </a>

        <p class="spl-thanks__footnote">
          Novidades, bastidores e acesso antecipado. Só pra quem está aqui.
        </p>
      </div>
    </div>
  </body>
</html>
